<section class="contenido">
  <div class="wrap">
    <p>
      De acuerdo a los requerimientos indicados en el Decreto 2150 de 2017, la solicitud consta de los puntos
      mencionados a continuación:
    </p>
    <p>
      <strong>CLAP</strong> es Asociación Centro Latinoamericano del Propósito, domiciliada en Calle 37 N° 12-46,
      Casa de la Cultura Custodio García Rovira Oficina 202, Bucaramanga.
    </p>

    <div class="datos">
      <p><strong>Nº Identificación Tributaria (NIT):</strong> 900712683-0</p>
      <p><strong>Matrícula Mercantil:</strong> Nº 512052 – Cámara de Comercio de Bucaramanga</p>
      <p><strong>Acta de Registro:</strong> Nº 46991 del Libro 1 – Entidades Sin Ánimo de Lucro (ESAL)</p>
    </div>

    <h2>Documentos de la solicitud</h2>
    <p>Para efectos de la solicitud, se incluyen los siguientes documentos.</p>

    <div class="accordion">
      {
        requisitos.map((r) => (
          <div class="accordion-item" class:list={[{ "is-open": r.numero === 1 }]}>
            <button
              type="button"
              class="accordion-trigger"
              aria-expanded={r.numero === 1 ? "true" : "false"}
            >
              <span class="accordion-number">{r.numero}</span>
              <span class="accordion-titulo">{r.titulo}</span>
              <span class="accordion-icon" aria-hidden="true"></span>
            </button>
            <div class="accordion-panel">
              <div class="accordion-content" set:html={r.html} />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  const items = document.querySelectorAll<HTMLElement>(".contenido .accordion-item");

  items.forEach((item) => {
    const trigger = item.querySelector<HTMLButtonElement>(".accordion-trigger");
    const panel = item.querySelector<HTMLElement>(".accordion-panel");
    if (!trigger || !panel) return;

    if (item.classList.contains("is-open")) {
      panel.style.maxHeight = `${panel.scrollHeight}px`;
    }

    trigger.addEventListener("click", () => {
      const isOpen = item.classList.contains("is-open");

      if (isOpen) {
        panel.style.maxHeight = "0px";
        item.classList.remove("is-open");
        trigger.setAttribute("aria-expanded", "false");
      } else {
        panel.style.maxHeight = `${panel.scrollHeight}px`;
        item.classList.add("is-open");
        trigger.setAttribute("aria-expanded", "true");
      }
    });
  });
</script>

