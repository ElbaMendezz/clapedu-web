---

<section id="contacto">
  <div class="blob" aria-hidden="true"></div>
  <div class="noise" aria-hidden="true"></div>
  <div class="ring ring--1" aria-hidden="true"></div>
  <div class="ring ring--2" aria-hidden="true"></div>

  <div class="container">
    <div class="intro" data-reveal="left">
      <div class="eyebrow">
        <span class="eyebrow-dot" aria-hidden="true"></span>
        <span>hablemos</span>
      </div>
      <h2>Únete a la comunidad que transforma</h2>
      <p>
        Cuéntanos en qué estás trabajando. Te contactamos para sumarte al
        ecosistema CLAP.
      </p>
      <div class="social-links">
        {
          socialLinks.map((social) => (
            <a href={social.href} target="_blank" rel="noopener" class="social-icon" aria-label={social.label}>
              {social.isInstagram ? (
                <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5"></rect>
                  <circle cx="12" cy="12" r="4"></circle>
                  <circle cx="17.5" cy="6.5" r="1.2" fill="#fff" stroke="none"></circle>
                </svg>
              ) : (
                <svg width={social.size} height={social.size} viewBox="0 0 24 24" fill="#fff">
                  <path d={social.path} />
                </svg>
              )}
            </a>
          ))
        }
      </div>
    </div>

    <div class="form-card" data-reveal="right">
      <div data-contact-form-state>
        <form data-contact-form>
          <label for="contact-name">Nombre</label>
          <input id="contact-name" name="name" required placeholder="Tu nombre" />

          <label for="contact-email">Email</label>
          <input id="contact-email" name="email" type="email" required placeholder="tucorreo@email.com" />

          <label for="contact-message">Mensaje</label>
          <textarea id="contact-message" name="message" rows="4" required placeholder="Cuéntanos sobre tu propósito..."></textarea>

          <button type="submit">Enviar mensaje</button>
        </form>
      </div>

      <div data-contact-success-state class="success">
        <div class="success-icon">✓</div>
        <h3>¡Gracias!</h3>
        <p>Recibimos tu mensaje. El equipo CLAP te contactará muy pronto.</p>
      </div>
    </div>
  </div>
</section>

<script>
  import { attachReveal } from "../../scripts/reveal";
  import { attachContactForm } from "../../scripts/contact-form";

  const section = document.querySelector<HTMLElement>("#contacto");
  if (section) {
    attachReveal(section);
    attachContactForm(section);
  }
</script>

<style>
  section {
    position: relative;
    overflow: hidden;
    background: linear-gradient(125deg, #2a1457, #43197c 45%, #13b89a);
    background-size: 200% 200%;
    animation: clap-gradient-shift 18s ease infinite;
    padding: 96px 48px;
  }

  .blob {
    position: absolute;
    right: -120px;
    top: -120px;
    width: 460px;
    height: 460px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(59, 224, 187, 0.4), transparent 70%);
    filter: blur(40px);
    animation: clap-float-b 16s ease-in-out infinite;
  }

  .noise {
    position: absolute;
    inset: 0;
    background-image: url("../../assets/images/noise-texture.png");
    opacity: 0.45;
    pointer-events: none;
  }

  .ring {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }
  .ring--1 {
    left: -220px;
    bottom: -260px;
    width: 720px;
    height: 720px;
    border: 1.5px solid rgba(255, 255, 255, 0.12);
  }
  .ring--2 {
    left: -300px;
    bottom: -340px;
    width: 940px;
    height: 940px;
    border: 1.5px solid rgba(255, 255, 255, 0.08);
  }

  .container {
    position: relative;
    max-width: 1080px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 16px;
    border: 1px solid rgba(59, 224, 187, 0.3);
    border-radius: 40px;
    margin-bottom: 20px;
    background: rgba(123, 77, 255, 0.15);
    backdrop-filter: blur(6px);
    font-family: var(--font-label);
    font-size: 13px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-white);
    font-weight: 600;
  }
  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-teal);
  }

  .intro h2 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 46px;
    letter-spacing: -0.025em;
    color: var(--color-white);
    line-height: 1.05;
    margin-bottom: 18px;
    text-wrap: balance;
  }

  .intro p {
    font-size: 17px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.82);
    margin-bottom: 34px;
    max-width: 380px;
  }

  .social-links {
    display: flex;
    gap: 13px;
  }
  .social-icon {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .social-icon:hover {
    background: var(--color-teal);
    transform: translateY(-3px);
  }

  .form-card {
    background: rgba(255, 255, 255, 0.97);
    border-radius: 28px;
    padding: 38px;
    box-shadow: 0 40px 80px -30px rgba(0, 0, 0, 0.4);
  }

  .form-card label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-ink-soft);
    margin-bottom: 7px;
  }

  .form-card input,
  .form-card textarea {
    width: 100%;
    font-family: var(--font-body);
    font-size: 15px;
    padding: 14px 16px;
    border: 1.5px solid #e6e0f2;
    border-radius: 14px;
    margin-bottom: 18px;
    outline: none;
    color: var(--color-ink);
    background: var(--color-white);
  }
  .form-card input:focus,
  .form-card textarea:focus {
    border-color: var(--color-teal);
  }
  .form-card textarea {
    resize: vertical;
    margin-bottom: 22px;
  }

  .form-card button[type="submit"] {
    width: 100%;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--color-white);
    background: var(--color-ink);
    border: none;
    padding: 16px;
    border-radius: 46px;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
  }
  .form-card button[type="submit"]:hover {
    background: var(--color-ink-strong);
    transform: translateY(-2px);
  }

  .success {
    display: none;
    text-align: center;
    padding: 40px 10px;
  }
  .success-icon {
    width: 74px;
    height: 74px;
    border-radius: 50%;
    background: #eafaf5;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 22px;
    font-size: 34px;
    color: #13b89a;
  }
  .success h3 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 24px;
    color: var(--color-ink);
    margin-bottom: 10px;
  }
  .success p {
    font-size: 15px;
    color: var(--color-ink-soft);
    line-height: 1.6;
  }

  @media (max-width: 1099.98px) {
    .container {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767.98px) {
    section {
      padding: 62px 22px;
    }
    .intro h2 {
      font-size: 32px;
    }
    .form-card {
      padding: 26px;
    }
  }
</style>
