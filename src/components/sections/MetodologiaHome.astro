---
interface ChecklistContent {
  type: "checklist";
  items: string[];
}
interface GridContent {
  type: "grid";
  items: { label: string; barColor: "teal" | "yellow" | "purple"; wide?: boolean }[];
}

interface Step {
  label: string;
  iconPaths: string;
  stepLabel: string;
  title: string;
  cardTitle: string;
  content: ChecklistContent | GridContent;
}

const steps: Step[] = [
  {
    label: "Explorar",
    iconPaths: '<circle cx="12" cy="12" r="9"></circle><polygon points="15.5 8.5 10.5 10.5 8.5 15.5 13.5 13.5"></polygon>',
    stepLabel: "paso 01",
    title: "Investiga el contexto, las necesidades y los actores clave para identificar problemas y oportunidades.",
    cardTitle: "¿Qué harás aquí?",
    content: {
      type: "checklist",
      items: ["Inmersión en el entorno.", "Exploración de la oportunidad.", "Analiza y articula"],
    },
  },
  {
    label: "Crear",
    iconPaths: '<path d="M9 18h6"></path><path d="M10 21h4"></path><path d="M12 3a6 6 0 0 0-4 10.5c.6.6 1 1.3 1 2.5h6c0-1.2.4-1.9 1-2.5A6 6 0 0 0 12 3Z"></path>',
    stepLabel: "paso 02",
    title: "Diseña técnicamente la solución y construye un plan de acción detallado.",
    cardTitle: "¿Qué harás aquí?",
    content: {
      type: "grid",
      items: [
        { label: "Crear la estrategia", barColor: "teal" },
        { label: "Crear el plan de trabajo", barColor: "yellow" },
        { label: "Articula y gestiona", barColor: "purple", wide: true },
      ],
    },
  },
  {
    label: "Actuar",
    iconPaths: '<path d="M22 2 11 13"></path><path d="M22 2 15 22l-4-9-9-4 20-7Z"></path>',
    stepLabel: "paso 03",
    title: "Ejecuta el plan de acción y realiza un seguimiento",
    cardTitle: "¿Qué harás aquí?",
    content: {
      type: "checklist",
      items: ["Ejecuta los pasos.", "Haz monitoreo."],
    },
  },
  {
    label: "Resolver",
    iconPaths: '<path d="M22 7 13.5 15.5 8.5 10.5 2 17"></path><path d="M16 7 22 7 22 13"></path>',
    stepLabel: "paso 04",
    title: "Mide el éxito de la intervención",
    cardTitle: "¿Qué harás?",
    content: {
      type: "checklist",
      items: [
        "Analiza el impacto generado",
        "Sistematiza las lecciones aprendidas.",
        "Genera resultados",
        "Evalúa el impacto.",
      ],
    },
  },
];
---

<section id="metodologia">
  <div class="blob" aria-hidden="true"></div>

  <div class="container">
    <div class="intro">
      <div class="eyebrow" data-reveal>
        <span class="eyebrow-dot" aria-hidden="true"></span>
        <span>¿qué hacemos?</span>
      </div>
      <h2 data-reveal>
        Haz parte del liderazgo que transforma con la <span class="accent">metodología CLAP</span>
      </h2>
      <p data-reveal>
        A través de programas de formación, innovación y acción en territorio,
        conectamos conocimiento, liderazgo y propósito para impulsar
        proyectos que transforman comunidades.
      </p>
    </div>

    <div class="stepper" data-met-root>
      <div class="step-list" data-met-list data-reveal="left">
        {steps.map((step, i) => (
          <button type="button" class="step-item" class:list={[{ "is-active": i === 0 }]} data-met-item data-step={i}>
            <span class="step-icon" data-met-icon>
              <svg width="25" height="25" viewBox="0 0 24 24" fill="none" stroke="#341C65" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={step.iconPaths} />
            </span>
            <span class="step-label" data-met-label>{step.label}</span>
            <span class="step-dot" data-met-dot>
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"></path>
              </svg>
            </span>
          </button>
        ))}
      </div>

      <div class="step-stage" data-met-stage data-reveal="right">
        {steps.map((step, i) => (
          <div class="step-panel" class:list={[{ "is-active": i === 0 }, `step-panel--${i}`]} data-met-panel data-step={i}>
            <div class="panel-hero">
              <div class="panel-ring" aria-hidden="true"></div>
              <div class="panel-arrow" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 17 17 7"></path><path d="M8 7h9v9"></path>
                </svg>
              </div>
              <span class="panel-step-label">{step.stepLabel}</span>
              <h3 class:list={[{ "panel-title--resolver": step.label === "Resolver" }]}>{step.title}</h3>
            </div>
            <div class="panel-card">
              <div class="panel-card-title">{step.cardTitle}</div>
              {step.content.type === "checklist" ? (
                <ul class="checklist">
                  {step.content.items.map((item) => (
                    <li>
                      <span class="check" aria-hidden="true">✓</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              ) : (
                <div class="mini-grid">
                  {step.content.items.map((item) => (
                    <div class="mini-card" class:list={[{ "mini-card--wide": item.wide }]}>
                      <span class={`mini-bar mini-bar--${item.barColor}`}></span>
                      <span class="mini-label">{item.label}</span>
                    </div>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="cta-row" data-reveal>
      <a href="/metodologia" class="cta">
        <span class="cta-label">Probar la metodología CLAP</span>
        <span class="cta-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 17 17 7"></path><path d="M8 7h9v9"></path>
          </svg>
        </span>
      </a>
    </div>
  </div>
</section>

<script>
  import { attachReveal } from "../../scripts/reveal";
  import { attachHomeMethodologyStepper } from "../../scripts/home-methodology-stepper";

  const section = document.querySelector<HTMLElement>("#metodologia");
  if (section) {
    attachReveal(section);
    const stepperRoot = section.querySelector<HTMLElement>("[data-met-root]");
    if (stepperRoot) attachHomeMethodologyStepper(stepperRoot);
  }
</script>

<style>
  section {
    position: relative;
    overflow: hidden;
    padding: 96px 48px 104px;
    background-color: #efeff5;
  }

  .blob {
    position: absolute;
    width: 480px;
    height: 480px;
    right: -140px;
    top: -120px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(59, 224, 187, 0.16), transparent 70%);
    filter: blur(40px);
    animation: clap-float-a 16s ease-in-out infinite;
  }

  .container {
    position: relative;
    max-width: 1180px;
    margin: 0 auto;
  }

  .intro {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 60px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 16px;
    border: 1px solid rgba(59, 224, 187, 0.3);
    border-radius: 40px;
    margin-bottom: 20px;
    background: rgba(123, 77, 255, 0.08);
    backdrop-filter: blur(6px);
    font-family: var(--font-label);
    font-size: 13px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-ink-strong);
    font-weight: 600;
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-teal);
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 44px;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    line-height: 1.08;
    margin-bottom: 20px;
    text-wrap: balance;
  }

  h2 .accent {
    color: var(--color-ink-strong);
  }

  .intro p {
    font-size: 17px;
    line-height: 1.65;
    color: var(--color-ink-soft);
  }

  /* -- Stepper: lista + stage lado a lado con flexbox (desktop) / apilados (mobile) -- */
  .stepper {
    display: flex;
    gap: 64px;
    align-items: center;
  }

  .step-list {
    flex: 0.92 1 0%;
    display: flex;
    flex-direction: column;
  }

  .step-item {
    position: relative;
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 24px 4px;
    cursor: pointer;
    border: none;
    border-bottom: 1px solid #d4cde4;
    background: none;
    width: 100%;
    text-align: left;
  }

  .step-icon {
    flex: none;
    width: 56px;
    height: 56px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.35s, transform 0.35s;
  }

  .step-label {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 26px;
    letter-spacing: -0.01em;
    color: #b9b2cc;
    transition: color 0.35s;
  }

  .step-item.is-active .step-label {
    color: var(--color-ink);
  }
  .step-item.is-active .step-icon {
    transform: scale(1.04);
  }
  .step-item[data-step="0"].is-active .step-icon { background: #ED5A8B; }
  .step-item[data-step="1"].is-active .step-icon { background: #F4B83E; }
  .step-item[data-step="2"].is-active .step-icon { background: #3FB85C; }
  .step-item[data-step="3"].is-active .step-icon { background: #4C8DD6; }

  .step-dot {
    margin-left: auto;
    flex: none;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #13b89a;
    opacity: 0;
    transform: scale(0.7);
    transition: opacity 0.35s, transform 0.35s;
    background-color: #d5e6df;
  }
  .step-item.is-active .step-dot {
    opacity: 1;
    transform: scale(1);
  }

  .step-stage {
    flex: 1.08 1 0%;
    position: relative;
    min-height: 520px;
  }

  .step-panel {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.55s ease, transform 0.55s ease;
    pointer-events: none;
  }
  .step-panel.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .panel-hero {
    position: relative;
    border-radius: 30px;
    overflow: hidden;
    padding: 46px 44px;
    min-height: 330px;
    box-shadow: 0 34px 70px -34px rgba(52, 28, 101, 0.55);
  }
  .step-panel--0 .panel-hero { background: linear-gradient(150deg, #43197c, #341c65 45%, #13b89a); }
  .step-panel--1 .panel-hero { background: linear-gradient(150deg, #341c65, #5a2a9e 50%, #43197c); }
  .step-panel--2 .panel-hero { background: linear-gradient(150deg, #13b89a, #0d3256 55%, #341c65); box-shadow: 0 34px 70px -34px rgba(13, 50, 86, 0.5); }
  .step-panel--3 .panel-hero { background: linear-gradient(150deg, #43197c, #13b89a); }

  .panel-ring {
    position: absolute;
    right: -50px;
    top: -50px;
    width: 200px;
    height: 200px;
    border: 1.5px solid rgba(59, 224, 187, 0.35);
    border-radius: 50%;
  }
  .step-panel--1 .panel-ring { border-color: rgba(255, 255, 255, 0.2); }
  .step-panel--3 .panel-ring { border-color: rgba(255, 255, 255, 0.25); }

  .panel-arrow {
    position: absolute;
    right: 30px;
    top: 30px;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-ink);
  }
  .step-panel--2 .panel-arrow { color: #0d3256; }

  .panel-step-label {
    position: relative;
    display: block;
    font-family: var(--font-label);
    font-size: 14px;
    color: var(--color-teal);
  }

  .panel-hero h3 {
    position: relative;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 34px;
    line-height: 1.18;
    color: var(--color-white);
    max-width: 460px;
    margin-top: 14px;
    text-wrap: balance;
  }
  .panel-title--resolver {
    padding-right: 72px;
  }

  .panel-card {
    position: relative;
    margin: -58px 28px 0;
    background: var(--color-white);
    border: 1px solid #efeaf8;
    border-radius: 22px;
    box-shadow: 0 24px 50px -28px rgba(52, 28, 101, 0.35);
    padding: 26px 28px;
  }

  .panel-card-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    color: var(--color-ink);
    margin-bottom: 18px;
  }

  .checklist {
    list-style: none;
  }
  .checklist li {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 0;
    border-bottom: 1px solid #f1eef8;
    font-size: 14.5px;
    color: #4a4663;
  }
  .checklist li:last-child {
    border-bottom: none;
  }
  .check {
    flex: none;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #13b89a;
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
  }

  .mini-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .mini-card {
    background: #f6f3fc;
    border-radius: 14px;
    padding: 14px 16px;
  }
  .mini-card--wide {
    grid-column: 1 / -1;
  }
  .mini-bar {
    display: block;
    width: 30px;
    height: 6px;
    border-radius: 4px;
    margin-bottom: 10px;
  }
  .mini-bar--teal { background: var(--color-teal); }
  .mini-bar--yellow { background: #ffc200; }
  .mini-bar--purple { background: #7b4dff; }
  .mini-label {
    display: block;
    font-size: 13.5px;
    font-weight: 700;
    color: var(--color-ink);
  }

  .cta-row {
    display: flex;
    justify-content: center;
    margin-top: 60px;
  }
  .cta {
    display: inline-flex;
    align-items: stretch;
    gap: 9px;
    text-decoration: none;
    transition: transform 0.25s;
  }
  .cta:hover {
    transform: translateY(-3px);
  }
  .cta-label {
    display: flex;
    align-items: center;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--color-white);
    background: var(--color-ink);
    padding: 16px 30px;
    border-radius: 16px;
    box-shadow: 0 16px 40px -16px rgba(52, 28, 101, 0.6);
  }
  .cta-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    border-radius: 16px;
    background: var(--color-ink);
    color: var(--color-white);
    box-shadow: 0 16px 40px -16px rgba(52, 28, 101, 0.6);
  }

  @media (max-width: 767.98px) {
    section {
      padding: 62px 22px;
    }
    h2 {
      font-size: 32px;
    }
    .stepper {
      display: block;
    }
    .step-stage {
      display: none;
      min-height: 0;
    }
    /* En móvil, home-methodology-stepper.ts reubica cada panel justo
       después de su item dentro de .step-list (acordeón) — ver script. */
    .step-list :global(.step-panel) {
      position: static;
      inset: auto;
      min-height: 0;
      overflow: hidden;
      opacity: 1;
      transform: none;
      pointer-events: auto;
      max-height: 0px;
      transition: max-height 0.6s cubic-bezier(0.4, 0.85, 0.3, 1);
      margin: 0;
    }
    .step-list :global(.step-panel.is-active) {
      margin: 12px 0 20px;
    }
    .panel-hero {
      padding: 26px 22px 52px;
      min-height: 0;
    }
    .panel-hero h3 {
      font-size: 21px;
      margin-top: 8px;
    }
    .panel-card {
      margin: -32px 10px 0;
    }
  }
</style>
