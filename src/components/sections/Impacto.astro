---
interface Metric {
  count: number;
  prefix: string;
  suffix?: string;
  display: string;
  label: string;
  color: "teal" | "yellow";
  delay: number;
  iconPaths: string;
}

const metrics: Metric[] = [
  {
    count: 42,
    prefix: "+",
    display: "+42",
    label: "Proyectos desarrollados",
    color: "teal",
    delay: 40,
    iconPaths: '<path d="M12 2 2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path>',
  },
  {
    count: 10000,
    prefix: "+$",
    suffix: " mill.",
    display: "+$10.000 mill.",
    label: "Ejecutados",
    color: "yellow",
    delay: 120,
    iconPaths: '<line x1="12" y1="2" x2="12" y2="22"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>',
  },
  {
    count: 15,
    prefix: "+",
    display: "+15",
    label: "Territorios impactados",
    color: "yellow",
    delay: 200,
    iconPaths: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle>',
  },
  {
    count: 15000,
    prefix: "+",
    display: "+15.000",
    label: "Beneficiarios directos",
    color: "teal",
    delay: 280,
    iconPaths: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path>',
  },
  {
    count: 10,
    prefix: "+",
    display: "+10",
    label: "Años de experiencia acumulada",
    color: "teal",
    delay: 360,
    iconPaths: '<circle cx="12" cy="12" r="9"></circle><polyline points="12 7 12 12 15 14"></polyline>',
  },
  {
    count: 150,
    prefix: "+",
    display: "+150",
    label: "Alumnos formados",
    color: "yellow",
    delay: 440,
    iconPaths: '<path d="M22 10 12 5 2 10l10 5 10-5z"></path><path d="M6 12v5c0 1 2.7 3 6 3s6-2 6-3v-5"></path>',
  },
];
---

<section id="impacto">
  <div class="blob blob--a" aria-hidden="true"></div>
  <div class="blob blob--b" aria-hidden="true"></div>
  <div class="noise" aria-hidden="true"></div>
  <div class="ring ring--1" aria-hidden="true"></div>
  <div class="ring ring--2" aria-hidden="true"></div>

  <div class="container">
    <div class="intro" data-reveal="left">
      <div class="eyebrow">
        <span class="eyebrow-dot" aria-hidden="true"></span>
        <span>nuestro impacto</span>
      </div>
      <h2>El impacto de actuar<br /><span class="accent">con propósito</span></h2>
      <p>Cada cifra representa propósito convertido en cambio real.</p>
      <a href="/#contacto" class="cta">
        Súmate al movimiento
        <span class="cta-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"></path><path d="M13 6l6 6-6 6"></path>
          </svg>
        </span>
      </a>
    </div>

    <div class="metrics-wrap">
      <div class="metrics-divider" aria-hidden="true"></div>
      <div class="metrics-grid">
        {metrics.map((metric) => (
          <div class="metric" data-reveal data-delay={metric.delay}>
            <span class={`metric-icon metric-icon--${metric.color}`}>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={metric.iconPaths} />
            </span>
            <span
              class={`metric-number metric-number--${metric.color}`}
              data-count={metric.count}
              data-prefix={metric.prefix}
              data-suffix={metric.suffix}
            >
              {metric.display}
            </span>
            <span class="metric-label">{metric.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { attachReveal } from "../../scripts/reveal";
  import { attachCountUp } from "../../scripts/count-up";

  const section = document.querySelector<HTMLElement>("#impacto");
  if (section) {
    attachReveal(section);
    attachCountUp(section);
  }
</script>

<style>
  section {
    position: relative;
    overflow: hidden;
    background: linear-gradient(120deg, #2a1457, #43197c 40%, #3b2a8a 64%, #13b89a);
    background-size: 220% 220%;
    animation: clap-gradient-shift 16s ease infinite;
    padding: 104px 48px;
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }
  .blob--a {
    width: 520px;
    height: 520px;
    left: -140px;
    top: -160px;
    background: radial-gradient(circle, #3be0bb, transparent 70%);
    opacity: 0.45;
    filter: blur(34px);
    animation: clap-float-a 13s ease-in-out infinite;
  }
  .blob--b {
    width: 460px;
    height: 460px;
    right: -120px;
    bottom: -140px;
    background: radial-gradient(circle, #7b4dff, transparent 70%);
    opacity: 0.5;
    filter: blur(36px);
    animation: clap-float-b 15s ease-in-out infinite;
  }

  .noise {
    position: absolute;
    inset: 0;
    background-image: url("../../assets/images/noise-texture.png");
    opacity: 0.5;
    pointer-events: none;
  }

  .ring {
    position: absolute;
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    pointer-events: none;
  }
  .ring--1 {
    left: -140px;
    top: -120px;
    width: 480px;
    height: 480px;
  }
  .ring--2 {
    right: -120px;
    bottom: -100px;
    width: 420px;
    height: 420px;
    border-color: rgba(59, 224, 187, 0.18);
  }

  .container {
    position: relative;
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 0.86fr 1.14fr;
    gap: 64px;
    align-items: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 16px;
    border: 1px solid rgba(59, 224, 187, 0.4);
    border-radius: 40px;
    margin-bottom: 24px;
    background: rgba(59, 224, 187, 0.1);
    backdrop-filter: blur(6px);
    font-family: var(--font-label);
    font-size: 13px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-teal);
    font-weight: 600;
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-teal);
  }

  .intro h2 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 42px;
    line-height: 1.02;
    letter-spacing: -0.025em;
    color: var(--color-white);
    text-transform: uppercase;
    text-wrap: balance;
  }

  .intro h2 .accent {
    color: var(--color-teal);
  }

  .intro p {
    font-size: 17px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.82);
    margin-top: 24px;
    max-width: 360px;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    gap: 11px;
    margin-top: 32px;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--color-ink);
    background: var(--color-teal);
    padding: 16px 30px;
    border-radius: 46px;
    text-decoration: none;
    box-shadow: 0 18px 40px -16px rgba(59, 224, 187, 0.7);
    transition: transform 0.25s, box-shadow 0.25s, background 0.25s;
  }
  .cta:hover {
    transform: translateY(-3px);
    background: #ffc200;
    box-shadow: 0 22px 46px -16px rgba(255, 194, 0, 0.6);
  }
  .cta-icon {
    display: flex;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: rgba(52, 28, 101, 0.16);
    align-items: center;
    justify-content: center;
  }

  .metrics-wrap {
    position: relative;
    padding-left: 64px;
  }

  .metrics-divider {
    position: absolute;
    left: 0;
    top: 6px;
    bottom: 6px;
    width: 1px;
    background: linear-gradient(to bottom, transparent, rgba(255, 255, 255, 0.35) 12%, rgba(255, 255, 255, 0.35) 88%, transparent);
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px 36px;
  }

  .metric {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 14px;
    align-items: center;
  }

  .metric-icon {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .metric-icon--teal {
    background: rgba(59, 224, 187, 0.16);
    border: 1px solid rgba(59, 224, 187, 0.4);
    color: var(--color-teal);
  }
  .metric-icon--yellow {
    background: rgba(255, 194, 0, 0.16);
    border: 1px solid rgba(255, 194, 0, 0.4);
    color: #ffc200;
  }

  .metric-number {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 42px;
    line-height: 0.9;
  }
  .metric-number--teal {
    color: var(--color-teal);
  }
  .metric-number--yellow {
    color: #ffc200;
  }

  .metric-label {
    grid-column: 1 / 3;
    font-size: 14.5px;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.82);
    margin-top: 10px;
    max-width: 200px;
  }

  @media (max-width: 1099.98px) {
    .container {
      grid-template-columns: 1fr;
    }
    .metrics-wrap {
      padding-left: 0;
      padding-top: 40px;
    }
    /* El divisor vertical no se reorienta: en tablet/mobile el original
       lo oculta por completo (no hay separación entre intro y métricas). */
    .metrics-divider {
      display: none;
    }
  }

  @media (max-width: 767.98px) {
    section {
      padding: 62px 22px;
    }
    .intro h2 {
      font-size: 32px;
    }
    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 28px 18px;
    }
    .metric-number {
      font-size: 32px;
    }
  }
</style>
