---
import { Image } from "astro:assets";
import logoPurple from "../../assets/images/logo-clap-purple.png";

const WHATSAPP_VOLUNTARIO =
  "https://api.whatsapp.com/send/?phone=3114481160&text&type=phone_number&app_absent=0&utm_source=ig";

const year = new Date().getFullYear();

const socialLinks = [
  {
    label: "WhatsApp",
    href: WHATSAPP_VOLUNTARIO,
    path: "M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-1.219zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.078 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z",
  },
  {
    label: "Facebook",
    href: "https://www.facebook.com/claplatam/",
    path: "M13.5 22v-9h3l.5-3.5h-3.5V7.2c0-1 .3-1.7 1.8-1.7H17V2.3C16.6 2.25 15.5 2.1 14.3 2.1c-2.6 0-4.3 1.55-4.3 4.4V9.5H7V13h3v9h3.5z",
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/company/claplatam/posts/?feedView=all",
    path: "M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.11 1 2.5 1s2.48 1.12 2.48 2.5zM0.25 8h4.5V23h-4.5V8zM8 8h4.3v2.05h.06c.6-1.13 2.06-2.32 4.24-2.32C21.2 7.73 22 10.06 22 14.1V23h-4.5v-7.9c0-1.88-.03-4.3-2.62-4.3-2.62 0-3.02 2.05-3.02 4.16V23H8V8z",
  },
  {
    label: "X",
    href: "https://x.com/claplatam",
    path: "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z",
  },
  {
    label: "YouTube",
    href: "https://www.youtube.com/channel/UCrw8CK1KtvkyAUrlJdn3YMQ",
    path: "M23.5 6.2a3.02 3.02 0 0 0-2.12-2.14C19.5 3.55 12 3.55 12 3.55s-7.5 0-9.38.51A3.02 3.02 0 0 0 .5 6.2C0 8.08 0 12 0 12s0 3.92.5 5.8a3.02 3.02 0 0 0 2.12 2.14c1.88.51 9.38.51 9.38.51s7.5 0 9.38-.51a3.02 3.02 0 0 0 2.12-2.14C24 15.92 24 12 24 12s0-3.92-.5-5.8zM9.6 15.6V8.4l6.2 3.6-6.2 3.6z",
  },
];
---

<footer>
  <div class="footer-grid">
    <div class="footer-brand">
      <a href="/#inicio" class="footer-logo">
        <Image src={logoPurple} alt="CLAP" height={34} />
      </a>
      <p>
        CLAP forma líderes capaces de convertir los desafíos sociales de
        Latinoamérica en soluciones reales.
      </p>
    </div>

    <nav class="footer-col" aria-label="Conócenos">
      <h4>Conócenos</h4>
      <a href="/#inicio">Inicio</a>
      <a href="/sobre-nosotros#que-es">Sobre nosotros</a>
      <a href="/sobre-nosotros#valores">Nuestros valores</a>
      <a href="/sobre-nosotros#filosofia">Nuestra filosofía</a>
      <a href="/sobre-nosotros#historia">Nuestra historia</a>
      <a href="/equipo">Equipo de trabajo</a>
    </nav>

    <nav class="footer-col" aria-label="Programas">
      <h4>Programas</h4>
      <a href="/programas">Programas Especializados</a>
      <a href="/programas#empresas">Programas Especializados Empresas</a>
    </nav>

    <nav class="footer-col" aria-label="Otros">
      <h4>Otros</h4>
      <a href="/politica-privacidad">Política de privacidad</a>
      <a href="/politica-privacidad">Tratamiento de datos</a>
    </nav>

    <div class="footer-col">
      <h4>¡Síguenos!</h4>
      <p class="footer-social-copy">Contáctanos por medio de nuestras redes sociales</p>
      <div class="social-links">
        {
          socialLinks.map((social) => (
            <a href={social.href} target="_blank" rel="noopener" class="social-icon" aria-label={social.label}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d={social.path} />
              </svg>
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <span>Copyright © {year} clapedu.org</span>
    <span>Powered by clapedu.org</span>
  </div>
</footer>

<style>
  footer {
    background: var(--color-white);
    color: var(--color-ink);
    padding: 64px 48px 0;
    border-top: 1px solid var(--color-border);
  }

  .footer-grid {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr 1fr;
    gap: 34px;
    padding-bottom: 48px;
  }

  .footer-logo {
    display: inline-block;
    margin-bottom: 22px;
  }

  .footer-brand p {
    font-size: 14.5px;
    line-height: 1.65;
    color: var(--color-ink-soft);
    max-width: 260px;
  }

  .footer-col h4 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 17px;
    color: var(--color-ink);
    margin-bottom: 18px;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 11px;
  }

  .footer-col a {
    font-size: 14px;
    color: var(--color-ink-soft);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-col a:hover {
    color: var(--color-teal-dark);
  }

  .footer-social-copy {
    font-size: 14px;
    color: var(--color-ink-soft);
    line-height: 1.6;
  }

  .social-links {
    display: flex;
    gap: 10px;
  }

  .social-icon {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: var(--color-social-bg);
    color: var(--color-ink-strong);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: background 0.2s;
  }

  .social-icon:hover {
    background: var(--color-teal);
  }

  .footer-bottom {
    max-width: var(--container-max);
    margin: 0 auto;
    border-top: 1px solid var(--color-border);
    padding: 22px 0;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px;
    font-size: 13px;
    color: #9b93bd;
  }

  @media (max-width: 1099.98px) and (min-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 767.98px) {
    footer {
      padding-left: 22px;
      padding-right: 22px;
    }
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
