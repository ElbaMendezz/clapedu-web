---
---

<section id="valores">
  <div class="container">
    <div class="intro">
      <div class="eyebrow" data-reveal>
        <span class="eyebrow-dot" aria-hidden="true"></span>
        <span>lo que nos mueve</span>
      </div>
      <h2 data-reveal>Nuestros <span class="accent">valores</span></h2>
      <p data-reveal>
        Cuatro principios que sostienen cada palabra, cada proyecto y cada
        liderazgo que formamos.
      </p>
    </div>

    <div class="wrap" data-val-wrap>
      <div class="col col--left">
        <div class="label is-hi-ready" data-vallabel data-vi="0" data-side="left" data-color="#13b89a">
          <div class="label-head">
            <span class="dot" data-valdot></span>
            <h3>DIVERSIDAD</h3>
          </div>
          <p>Respetamos y aprendemos de las diferencias.</p>
        </div>
        <div class="label" data-vallabel data-vi="2" data-side="left" data-color="#7b4dff">
          <div class="label-head">
            <span class="dot" data-valdot></span>
            <h3>INTEGRIDAD</h3>
          </div>
          <p>Somos conscientes y responsables de nuestras acciones.</p>
        </div>
      </div>

      <div class="box" data-val-box>
        <div class="cell cell--0" data-valcell="0" data-vi="0">
          <div class="icon">
            <svg viewBox="0 0 80 80" width="78" height="78" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <g stroke="#13b89a" stroke-width="2" opacity="0.45">
                <line x1="40" y1="40" x2="16" y2="16"></line>
                <line x1="40" y1="40" x2="64" y2="16"></line>
                <line x1="40" y1="40" x2="16" y2="60"></line>
                <line x1="40" y1="40" x2="64" y2="60"></line>
              </g>
              <circle cx="40" cy="40" r="15" fill="#E7F7F2" stroke="#341C65" stroke-width="3"></circle>
              <ellipse cx="40" cy="40" rx="6.5" ry="15" stroke="#341C65" stroke-width="2.2"></ellipse>
              <line x1="25" y1="40" x2="55" y2="40" stroke="#341C65" stroke-width="2.2"></line>
              <g class="val-green">
                <circle cx="16" cy="13" r="4.4" fill="#13b89a"></circle>
                <path d="M9 24a7 7 0 0 1 14 0z" fill="#13b89a"></path>
              </g>
              <g>
                <circle cx="64" cy="13" r="4.4" fill="#7b4dff"></circle>
                <path d="M57 24a7 7 0 0 1 14 0z" fill="#7b4dff"></path>
              </g>
              <g>
                <circle cx="16" cy="57" r="4.4" fill="#FFC200"></circle>
                <path d="M9 68a7 7 0 0 1 14 0z" fill="#FFC200"></path>
              </g>
              <g>
                <circle cx="64" cy="57" r="4.4" fill="#CE6711"></circle>
                <path d="M57 68a7 7 0 0 1 14 0z" fill="#CE6711"></path>
              </g>
            </svg>
          </div>
          <span class="mini-title" data-valminititle>DIVERSIDAD</span>
        </div>

        <div class="cell cell--1" data-valcell="1" data-vi="1">
          <div class="icon">
            <svg viewBox="0 0 80 80" width="78" height="78" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path d="M33 44 L27 67 L36 60 L40 68 L44 60 L53 67 L47 44 Z" fill="#7b4dff" stroke="#341C65" stroke-width="2.5"></path>
              <circle cx="40" cy="33" r="17" fill="#FFC200" stroke="#341C65" stroke-width="3"></circle>
              <circle cx="40" cy="33" r="10" fill="#FFD84D" stroke="#fff" stroke-width="2"></circle>
              <path d="M40 27 a6 6 0 0 0 0 12" stroke="#fff" stroke-width="2.5" opacity="0.85" fill="none"></path>
              <path d="M63 15 l1.4 3.4 3.4 1.4 -3.4 1.4 -1.4 3.4 -1.4 -3.4 -3.4 -1.4 3.4 -1.4 z" fill="#13b89a"></path>
            </svg>
          </div>
          <span class="mini-title" data-valminititle>EXCELENCIA</span>
        </div>

        <div class="cell cell--2" data-valcell="2" data-vi="2">
          <div class="icon">
            <svg viewBox="0 0 80 80" width="78" height="78" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 71 q0 -17 21 -17 q21 0 21 17 z" fill="#7b4dff" stroke="#341C65" stroke-width="3"></path>
              <path d="M40 55 l2.3 4.8 5.2 .5 -3.9 3.5 1.1 5.1 -4.7 -2.7 -4.7 2.7 1.1 -5.1 -3.9 -3.5 5.2 -.5 z" fill="#FFC200" stroke="#341C65" stroke-width="1.3"></path>
              <circle cx="40" cy="29" r="14" fill="#FFD9C2" stroke="#341C65" stroke-width="3"></circle>
              <path d="M26 27 a14 14 0 0 1 28 0 l-5 4 q-9 -4 -18 0 z" fill="#43197C" stroke="#341C65" stroke-width="2.5"></path>
              <circle cx="34.5" cy="30" r="1.9" fill="#341C65"></circle>
              <circle cx="45.5" cy="30" r="1.9" fill="#341C65"></circle>
              <path d="M35 37 q5 4 10 0" stroke="#341C65" stroke-width="2" fill="none"></path>
            </svg>
          </div>
          <span class="mini-title" data-valminititle>INTEGRIDAD</span>
        </div>

        <div class="cell cell--3" data-valcell="3" data-vi="3">
          <div class="icon">
            <svg viewBox="0 0 80 80" width="78" height="78" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path d="M40 66 L40 38" stroke="#341C65" stroke-width="3.4"></path>
              <path d="M40 44 Q24 44 20 28 Q36 28 40 44 Z" fill="#13b89a" stroke="#341C65" stroke-width="3"></path>
              <path d="M40 38 Q56 36 60 22 Q44 22 40 38 Z" fill="#3BE0BB" stroke="#341C65" stroke-width="3"></path>
              <path d="M30 66 Q40 60 50 66" stroke="#341C65" stroke-width="3" fill="none"></path>
              <circle cx="40" cy="34" r="2.4" fill="#FFC200" stroke="#341C65" stroke-width="1.4"></circle>
            </svg>
          </div>
          <span class="mini-title" data-valminititle>POSIBILIDAD</span>
        </div>
      </div>

      <div class="col col--right">
        <div class="label" data-vallabel data-vi="1" data-side="right" data-color="#ce6711">
          <div class="label-head">
            <span class="dot" data-valdot></span>
            <h3>EXCELENCIA</h3>
          </div>
          <p>Entregamos siempre lo mejor de nosotros.</p>
        </div>
        <div class="label" data-vallabel data-vi="3" data-side="right" data-color="#e8a400">
          <div class="label-head">
            <span class="dot" data-valdot></span>
            <h3>POSIBILIDAD</h3>
          </div>
          <p>Creemos en el poder transformador de las personas.</p>
        </div>
      </div>
    </div>

    <div class="mobile-card" data-valcard>
      <div class="mobile-card-head">
        <span class="mobile-card-dot" data-valcard-dot></span>
        <h3 data-valcard-title>DIVERSIDAD</h3>
      </div>
      <p data-valcard-desc>Respetamos y aprendemos de las diferencias.</p>
    </div>
  </div>
</section>

<script>
  import { attachReveal } from "../../scripts/reveal";
  import { attachValoresGrid } from "../../scripts/valores-grid";

  const section = document.querySelector<HTMLElement>("#valores");
  if (section) {
    attachReveal(section, { rootMargin: "0px 0px -8% 0px", repeat: false });
    attachValoresGrid(section);
  }
</script>

<style>
  section {
    position: relative;
    background: var(--color-white);
    padding: 94px 48px;
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .intro {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 52px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 16px;
    border: 1px solid rgba(59, 224, 187, 0.3);
    border-radius: 40px;
    margin-bottom: 18px;
    background: rgba(123, 77, 255, 0.08);
    font-family: var(--font-label);
    font-size: 13px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-ink-strong);
    font-weight: 400;
  }
  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-teal);
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 44px;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    line-height: 1.08;
    text-wrap: balance;
  }
  h2 .accent {
    color: #13b89a;
  }

  .intro p {
    font-size: 16px;
    line-height: 1.65;
    color: var(--color-ink-soft);
    margin-top: 12px;
  }

  .wrap {
    display: grid;
    grid-template-columns: 1fr 340px 1fr;
    align-items: stretch;
    max-width: 1080px;
    margin: 0 auto;
  }

  .col {
    display: grid;
    grid-template-rows: 1fr 1fr;
  }
  .col--left {
    justify-items: end;
  }
  .col--right {
    justify-items: start;
  }

  .label {
    display: flex;
    flex-direction: column;
    justify-content: center;
    transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.34, 1.4, 0.5, 1);
  }
  .col--left .label {
    align-items: flex-end;
    text-align: right;
    padding: 0 50px 0 0;
  }
  .col--right .label {
    align-items: flex-start;
    text-align: left;
    padding: 0 0 0 50px;
  }

  .label-head {
    display: flex;
    align-items: center;
    gap: 11px;
    margin-bottom: 8px;
  }

  .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex: none;
    box-shadow: 0 0 0 0 transparent;
    transition: transform 0.35s, box-shadow 0.35s;
  }
  .label[data-vi="0"] .dot { background: #13b89a; }
  .label[data-vi="1"] .dot { background: #ce6711; }
  .label[data-vi="2"] .dot { background: #7b4dff; }
  .label[data-vi="3"] .dot { background: #e8a400; }

  .label h3 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 21px;
    letter-spacing: 0.015em;
    color: var(--color-ink);
    margin: 0;
    transition: color 0.3s ease, transform 0.4s cubic-bezier(0.34, 1.5, 0.5, 1);
  }

  .label p {
    font-size: 15px;
    line-height: 1.55;
    color: var(--color-ink-soft);
    margin: 0;
    max-width: 215px;
    font-weight: 500;
    transition: color 0.3s ease, transform 0.4s cubic-bezier(0.34, 1.5, 0.5, 1);
  }

  .label.is-hi .dot {
    transform: scale(1.6);
  }
  .label[data-vi="0"].is-hi .dot { box-shadow: 0 0 0 5px rgba(19, 184, 154, 0.16); }
  .label[data-vi="1"].is-hi .dot { box-shadow: 0 0 0 5px rgba(206, 103, 17, 0.16); }
  .label[data-vi="2"].is-hi .dot { box-shadow: 0 0 0 5px rgba(123, 77, 255, 0.16); }
  .label[data-vi="3"].is-hi .dot { box-shadow: 0 0 0 5px rgba(232, 164, 0, 0.16); }
  .label[data-vi="0"].is-hi h3 { color: #13b89a; }
  .label[data-vi="1"].is-hi h3 { color: #ce6711; }
  .label[data-vi="2"].is-hi h3 { color: #7b4dff; }
  .label[data-vi="3"].is-hi h3 { color: #e8a400; }
  .col--left .label.is-hi h3,
  .col--left .label.is-hi p { transform: translateX(4px); }
  .col--right .label.is-hi h3,
  .col--right .label.is-hi p { transform: translateX(-4px); }
  .label.is-hi p { color: #4a4760; }

  .box {
    position: relative;
    width: 340px;
    height: 340px;
    border-radius: 24px;
    overflow: hidden;
    background: #ffc200;
    padding: 3px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 3px;
    box-shadow: 0 26px 60px -28px rgba(206, 103, 17, 0.55);
  }

  .cell {
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    /* Solo el fondo transiciona aquí — el hover (.is-hi) usa esto. La
       entrada "ensamblada" usa @keyframes por separado (más abajo) para
       que no le deje un transition-delay pegado al hover una vez corrida. */
    transition: background 0.4s ease;
  }
  .cell--0 { border-radius: 21px 0 0 0; --cell-off: translate(-52px, -52px) scale(0.6); }
  .cell--1 { border-radius: 0 21px 0 0; background-color: #faf6ff; --cell-off: translate(52px, -52px) scale(0.6); }
  .cell--2 { border-radius: 0 0 0 21px; --cell-off: translate(-52px, 52px) scale(0.6); }
  .cell--3 { border-radius: 0 0 21px 0; --cell-off: translate(52px, 52px) scale(0.6); }

  .icon {
    width: 78px;
    height: 78px;
    /* Solo transform transiciona aquí (para el scale del hover) — la
       entrada usa @keyframes, ver más abajo. */
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), filter 0.3s ease;
  }

  .mini-title {
    display: none;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 11.5px;
    letter-spacing: 0.03em;
    color: #8a8699;
    text-align: center;
    transition: color 0.3s;
  }

  .cell--0.is-hi { background: #13b89a; }
  .cell--1.is-hi { background: #ce6711; }
  .cell--2.is-hi { background: #7b4dff; }
  .cell--3.is-hi { background: #e8a400; }
  .cell.is-hi .icon { transform: scale(1.1); }
  .cell.is-hi .val-green circle,
  .cell.is-hi .val-green path {
    fill: #fff;
  }

  /* -- Ensamblado (solo ≥1000px, ver media query mobile más abajo): piezas
     ocultas hasta que la sección entra en viewport. Usa @keyframes en vez
     de transition+transition-delay para que NO le quede un delay pegado
     a las transiciones de hover (background del cell, scale del icon)
     una vez que la animación de entrada ya corrió — ese era el bug real:
     el hover "no pasaba nada" hasta 0.7s después porque heredaba el
     delay del ensamblado. -- */
  .box,
  .cell,
  .label {
    opacity: 0;
  }
  .box {
    transform: scale(0.92);
  }
  .cell {
    transform: var(--cell-off);
  }
  .cell .icon {
    opacity: 0;
    transform: scale(0.4);
  }
  .col--left .label { transform: translateX(-26px); }
  .col--right .label { transform: translateX(26px); }

  @keyframes val-box-in {
    to { opacity: 1; transform: scale(1); }
  }
  @keyframes val-cell-in {
    to { opacity: 1; transform: translate(0, 0) scale(1); }
  }
  @keyframes val-icon-in {
    to { opacity: 1; transform: scale(1); }
  }
  @keyframes val-label-in {
    to { opacity: 1; transform: translateX(0); }
  }

  /* Ensamblado activo SOLO ≥1000px — en mobile el media query de abajo
     fuerza todo visible sin animación (igual que el original, que ahí
     fuerza __shown=true/opacity:1 sin pasar por el IntersectionObserver
     de ensamblado en absoluto). */
  @media (min-width: 1000px) {
    .wrap.is-assembled .box {
      animation: val-box-in 0.5s cubic-bezier(0.34, 1.4, 0.5, 1) forwards;
    }
    .wrap.is-assembled .cell {
      animation: val-cell-in 0.6s cubic-bezier(0.34, 1.5, 0.5, 1) forwards;
      animation-delay: 0.22s;
    }
    .wrap.is-assembled .cell:nth-child(2) { animation-delay: 0.38s; }
    .wrap.is-assembled .cell:nth-child(3) { animation-delay: 0.54s; }
    .wrap.is-assembled .cell:nth-child(4) { animation-delay: 0.7s; }
    .wrap.is-assembled .cell .icon {
      animation: val-icon-in 0.5s ease forwards;
      animation-delay: 0.45s;
    }
    .wrap.is-assembled .cell:nth-child(2) .icon { animation-delay: 0.61s; }
    .wrap.is-assembled .cell:nth-child(3) .icon { animation-delay: 0.77s; }
    .wrap.is-assembled .cell:nth-child(4) .icon { animation-delay: 0.93s; }
    .wrap.is-assembled .label {
      animation: val-label-in 0.6s cubic-bezier(0.34, 1.4, 0.5, 1) forwards;
      animation-delay: 0.22s;
    }
    .wrap.is-assembled .col--left .label:nth-child(2),
    .wrap.is-assembled .col--right .label:nth-child(2) {
      animation-delay: 0.54s;
    }
  }

  .mobile-card {
    display: none;
    max-width: 420px;
    margin: 24px auto 0;
    background: var(--color-white);
    border: 1px solid rgba(206, 103, 17, 0.12);
    border-radius: 20px;
    padding: 22px 24px;
    box-shadow: 0 18px 40px -24px rgba(180, 90, 20, 0.4);
    text-align: center;
  }
  .mobile-card-head {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 8px;
  }
  .mobile-card-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #13b89a;
    flex: none;
  }
  .mobile-card-head h3 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 22px;
    letter-spacing: 0.015em;
    color: var(--color-ink);
    margin: 0;
  }
  .mobile-card p {
    font-size: 15px;
    line-height: 1.55;
    color: var(--color-ink-soft);
    margin: 0;
    font-weight: 500;
  }

  @media (max-width: 999.98px) {
    .wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .col {
      display: none;
    }
    .box {
      margin: 0 auto;
      width: min(340px, 82vw);
      height: min(340px, 82vw);
      opacity: 1;
      transform: none;
    }
    .cell {
      opacity: 1;
      transform: none;
      flex-direction: column;
      gap: 7px;
    }
    .cell .icon {
      opacity: 1;
      transform: none;
    }
    .cell--0.is-selected { background: #13b89a; }
    .cell--1.is-selected { background: #ce6711; }
    .cell--2.is-selected { background: #7b4dff; }
    .cell--3.is-selected { background: #e8a400; }
    .cell.is-selected .icon { transform: scale(1.06); }
    .cell.is-selected .val-green circle,
    .cell.is-selected .val-green path {
      fill: #fff;
    }
    .mini-title {
      display: block;
    }
    .cell:not(.cell--3).is-selected .mini-title {
      color: #fff;
    }
    .cell--3.is-selected .mini-title {
      color: var(--color-ink);
    }
    .mobile-card {
      display: block;
    }
  }

  @media (max-width: 767.98px) {
    section {
      padding-left: 22px;
      padding-right: 22px;
    }
    h2 {
      font-size: 34px;
    }
  }
</style>
