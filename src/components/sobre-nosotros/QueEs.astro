---
import { Image } from "astro:assets";
import heroImage from "../../assets/images/hero-sobre-manos.webp";
---

<section id="que-es">
  <div class="bg">
    <Image src={heroImage} alt="Equipo CLAP" width={1600} height={900} loading="eager" fetchpriority="high" layout="constrained" />
    <div class="scrim scrim--horizontal" aria-hidden="true"></div>
    <div class="scrim scrim--vertical" aria-hidden="true"></div>
  </div>

  <div class="content">
    <div class="inner">
      <div class="eyebrow">
        <span class="eyebrow-dot" aria-hidden="true"></span>
        <span>¿Qué es CLAP?</span>
      </div>
      <h1>Somos <span class="accent">CLAP</span></h1>
      <p>
        El Centro Latinoamericano del Propósito (CLAP) es una institución
        que forma líderes y lideresas capaces de resolver problemas
        sociales complejos en Latinoamérica.
      </p>
    </div>
  </div>
</section>

<style>
  section {
    position: relative;
    overflow: hidden;
    background: #1a0f36;
    display: flex;
    align-items: center;
    min-height: 640px;
    padding-top: 96px;
  }

  .bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 42%;
  }

  .scrim {
    position: absolute;
    inset: 0;
  }
  .scrim--horizontal {
    background: linear-gradient(
      90deg,
      rgba(22, 12, 46, 0.94) 0%,
      rgba(26, 15, 54, 0.82) 28%,
      rgba(26, 15, 54, 0.4) 52%,
      rgba(26, 15, 54, 0.06) 74%,
      transparent 100%
    );
  }
  .scrim--vertical {
    background: linear-gradient(
      180deg,
      rgba(22, 12, 46, 0.45),
      transparent 26%,
      transparent 64%,
      rgba(15, 8, 38, 0.7)
    );
  }

  .content {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: 48px 48px 60px;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: start;
  }

  .inner {
    max-width: 600px;
    display: flex;
    flex-direction: column;
    align-items: start;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 17px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 40px;
    margin-bottom: 26px;
    backdrop-filter: blur(6px);
    animation: clap-fade-up-in 0.7s ease both;
    font-family: var(--font-label);
    font-size: 14px;
    letter-spacing: 0.05em;
    color: var(--color-white);
    font-weight: 300;
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-teal);
    animation: clap-pulse-dot 2.4s ease-in-out infinite;
  }

  h1 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 58px;
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: var(--color-white);
    margin-bottom: 24px;
    text-wrap: balance;
    animation: clap-fade-up-in 0.8s ease 0.08s both;
  }
  h1 .accent {
    color: var(--color-teal);
    text-shadow: 0 0 38px rgba(59, 224, 187, 0.6);
  }

  p {
    font-weight: 400;
    font-size: 18px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.88);
    max-width: 500px;
    animation: clap-fade-up-in 0.8s ease 0.16s both;
  }

  @media (max-width: 767.98px) {
    section {
      min-height: 560px;
    }
    .content {
      padding: 40px 22px 48px;
    }
  }

  /* Breakpoints exactos del original para el h1 (heroH1.style.fontSize:
     w<640→38px, w<900→46px, si no 58px) — no son los 768/1100 estándar
     del resto del proyecto, son propios de esta sección. */
  @media (max-width: 899.98px) {
    h1 {
      font-size: 46px;
    }
  }
  @media (max-width: 639.98px) {
    h1 {
      font-size: 38px;
    }
  }
</style>
