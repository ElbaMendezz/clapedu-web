---
---

<section id="circulo">
  <div class="blob blob--1" aria-hidden="true"></div>
  <div class="blob blob--2" aria-hidden="true"></div>
  <div class="blob blob--3" aria-hidden="true"></div>
  <div class="blob blob--4" aria-hidden="true"></div>
  <div class="blob blob--5" aria-hidden="true"></div>
  <div class="grain grain--overlay" aria-hidden="true"></div>
  <div class="grain grain--multiply" aria-hidden="true"></div>

  <div class="container">
    <div class="intro">
      <div class="eyebrow" data-reveal>
        <span class="eyebrow-dot" aria-hidden="true"></span>
        <span>hablemos de geometría</span>
      </div>
      <h2 data-reveal>Nuestro <span class="accent">círculo dorado</span></h2>
      <p data-reveal>
        No empezamos por el "qué". Empezamos por el porqué: el eco que da
        sentido a todo lo que hacemos.
      </p>
    </div>

    <div class="grid" data-circ-grid>
      <div class="diagram-col" data-reveal="left">
        <div class="diagram" data-circ-diagram>
          <div class="ring ring--outer" data-circring="2">
            <span class="ring-label">qué</span>
          </div>
          <div class="ring ring--mid" data-circring="1">
            <span class="ring-label">cómo</span>
          </div>
          <div class="ring ring--center" data-circring="0">
            <span class="ring-label ring-label--center">por qué</span>
          </div>
          <div class="hint" data-circ-hint>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 11.24V7.5a2.5 2.5 0 0 1 5 0V12"></path>
              <path d="M14 10.5a2.5 2.5 0 0 1 5 0V14a8 8 0 0 1-8 8h-1a8 8 0 0 1-7-4.5l-1.5-3a2 2 0 0 1 3.5-2L9 14"></path>
            </svg>
            <span class="hint-text hint-text--desktop">Pasa el cursor por los círculos</span>
            <span class="hint-text hint-text--mobile">Toca los círculos</span>
          </div>
        </div>
      </div>

      <div class="list" data-reveal="right">
        <div class="item is-active" data-circitem="0">
          <div class="item-head">
            <span class="item-icon item-icon--teal">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path>
              </svg>
            </span>
            <span class="item-question">¿Por qué hacemos lo que hacemos?</span>
          </div>
          <p class="item-answer">
            Para resolver <strong class="hl hl--teal">problemas sociales complejos</strong> en
            América Latina.<br />Es nuestro punto de partida y nuestra razón de ser.
          </p>
        </div>

        <div class="item" data-circitem="1">
          <div class="item-head">
            <span class="item-icon item-icon--purple">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 18h6"></path>
                <path d="M10 22h4"></path>
                <path d="M12 2a7 7 0 0 0-4 12.5c.6.6 1 1.3 1 2.5h6c0-1.2.4-1.9 1-2.5A7 7 0 0 0 12 2Z"></path>
              </svg>
            </span>
            <span class="item-question">¿Cómo lo hacemos?</span>
          </div>
          <p class="item-answer">
            Formando <strong class="hl hl--ink">líderes innovadores</strong>, capaces de
            convertir los desafíos de su comunidad en oportunidades de cambio.
          </p>
        </div>

        <div class="item" data-circitem="2">
          <div class="item-head">
            <span class="item-icon item-icon--navy">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m12 2 9 5-9 5-9-5 9-5Z"></path>
                <path d="m3 12 9 5 9-5"></path>
                <path d="m3 17 9 5 9-5"></path>
              </svg>
            </span>
            <span class="item-question">¿Qué hacemos?</span>
          </div>
          <p class="item-answer">
            <strong class="hl hl--navy">Programas educativos, proyectos de intervención y
            eventos de incidencia</strong> que llevan el liderazgo al territorio.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { attachReveal } from "../../scripts/reveal";
  import { attachCirculoDorado } from "../../scripts/circulo-dorado";

  const section = document.querySelector<HTMLElement>("#circulo");
  if (section) {
    attachReveal(section, { rootMargin: "0px 0px -8% 0px", repeat: false });
    attachCirculoDorado(section);
  }
</script>

<style>
  section {
    position: relative;
    overflow: hidden;
    background: linear-gradient(160deg, #d2680f 0%, #f0951a 42%, #ffc21f 100%);
    padding: 96px 48px 104px;
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    will-change: transform;
  }
  .blob--1 {
    width: 60%;
    height: 84%;
    right: -12%;
    top: -24%;
    background: radial-gradient(circle, rgba(206, 103, 17, 0.85), transparent 54%);
    filter: blur(50px);
    animation: circ-drift-a 7s ease-in-out infinite;
  }
  .blob--2 {
    width: 56%;
    height: 78%;
    left: -14%;
    bottom: -24%;
    background: radial-gradient(circle, rgba(255, 194, 0, 0.88), transparent 55%);
    filter: blur(52px);
    animation: circ-drift-b 8.5s ease-in-out infinite;
  }
  .blob--3 {
    width: 42%;
    height: 58%;
    left: 38%;
    top: 24%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.7), transparent 56%);
    filter: blur(52px);
    animation: circ-drift-c 10s ease-in-out infinite;
  }
  .blob--4 {
    width: 46%;
    height: 64%;
    left: -8%;
    top: -16%;
    background: radial-gradient(circle, rgba(255, 194, 0, 0.7), transparent 54%);
    filter: blur(50px);
    animation: circ-drift-c 12s ease-in-out infinite reverse;
  }
  .blob--5 {
    width: 48%;
    height: 66%;
    right: -10%;
    bottom: -20%;
    background: radial-gradient(circle, rgba(206, 103, 17, 0.72), transparent 54%);
    filter: blur(50px);
    animation: circ-drift-a 11s ease-in-out infinite reverse;
  }

  @keyframes circ-drift-a {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(28%, -22%) scale(1.4); }
  }
  @keyframes circ-drift-b {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-26%, 24%) scale(1.36); }
  }
  @keyframes circ-drift-c {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(24%, 20%) scale(1.42); }
    66% { transform: translate(-22%, -18%) scale(1.16); }
  }

  .grain {
    position: absolute;
    inset: 0;
    background-image: url("../../assets/images/grain.png");
    background-size: 300px auto;
    pointer-events: none;
  }
  .grain--overlay {
    opacity: 0.95;
    mix-blend-mode: overlay;
  }
  .grain--multiply {
    opacity: 0.28;
    mix-blend-mode: multiply;
  }

  .container {
    position: relative;
    max-width: 1180px;
    margin: 0 auto;
  }

  .intro {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 56px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 16px;
    border: 1px solid rgba(206, 103, 17, 0.45);
    border-radius: 40px;
    margin-bottom: 18px;
    background-color: rgba(222, 195, 153, 0.5);
    font-family: var(--font-label);
    font-size: 13px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-white);
    font-weight: 400;
  }
  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #ce6711;
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 44px;
    letter-spacing: -0.025em;
    color: #f5f0ff;
    line-height: 1.08;
    text-wrap: balance;
  }

  .intro p {
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.74);
    margin-top: 12px;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .diagram-col {
    display: flex;
    justify-content: center;
  }

  .diagram {
    position: relative;
    width: 400px;
    height: 400px;
    transform-origin: center;
  }

  .ring {
    position: absolute;
    border-radius: 50%;
    background: transparent;
    border: 2.5px solid rgba(255, 255, 255, 0.92);
    display: flex;
    justify-content: center;
    cursor: pointer;
    transition: background 0.45s ease, border-color 0.4s, box-shadow 0.55s ease;
    box-shadow: 0 0 26px rgba(255, 255, 255, 0.5);
  }
  .ring--outer {
    inset: 0;
    align-items: flex-start;
    padding-top: 22px;
    box-shadow: 0 0 28px rgba(255, 255, 255, 0.55);
  }
  .ring--mid {
    inset: 75px;
    align-items: flex-start;
    padding-top: 20px;
  }
  .ring--center {
    inset: 145px;
    align-items: center;
  }

  .ring--outer.is-active { border-color: #0e2a52; }
  .ring--mid.is-active { border-color: #5a1e96; }
  .ring--center.is-active { border-color: #13b89a; }
  .ring.is-active {
    box-shadow: 0 0 60px rgba(255, 255, 255, 0.9);
  }

  .ring--outer.is-filled {
    background: radial-gradient(circle at 34% 26%, #234f8f 0%, #0f2c56 52%, #05152b 100%);
  }
  .ring--mid.is-filled {
    background: radial-gradient(circle at 34% 26%, #9248db 0%, #5d2099 52%, #371062 100%);
  }
  .ring--center.is-filled {
    background: radial-gradient(circle at 34% 26%, #3ce8cc 0%, #16bd9f 52%, #0b8870 100%);
  }

  .ring-label {
    font-family: var(--font-label);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fff;
  }
  .ring-label--center {
    font-family: var(--font-label);
    font-weight: 800;
    font-size: 15px;
    letter-spacing: 0.08em;
  }

  :global(.circ-burst) {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.55);
    pointer-events: none;
    animation: circ-burst 1.5s ease-out forwards;
  }
  @keyframes circ-burst {
    0% { transform: scale(1); opacity: 0.45; }
    100% { transform: scale(1.32); opacity: 0; }
  }

  .hint {
    position: absolute;
    left: 50%;
    bottom: -64px;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 9px 16px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.16);
    border: 1px solid rgba(255, 255, 255, 0.6);
    box-shadow: 0 0 24px rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(6px);
    white-space: nowrap;
    color: #fff;
    font-family: var(--font-label);
    font-size: 12.5px;
    letter-spacing: 0.04em;
    pointer-events: none;
    animation: circ-hint-float 2.6s ease-in-out infinite;
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .hint.is-hidden {
    opacity: 0;
    transform: translateX(-50%) translateY(8px);
    animation: none;
  }
  @keyframes circ-hint-float {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(-6px); }
  }

  .hint-text--mobile {
    display: none;
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .item {
    cursor: pointer;
    border-radius: 20px;
    border: 1px solid rgba(206, 103, 17, 0.08);
    background: #fffdf9;
    padding: 22px 24px;
    box-shadow: 0 14px 34px -20px rgba(180, 90, 20, 0.34);
    transition: background 0.45s ease, border-color 0.45s ease, box-shadow 0.45s ease;
  }
  .item.is-active {
    background: #ffffff;
    border-color: rgba(206, 103, 17, 0.18);
    box-shadow: 0 24px 52px -22px rgba(180, 90, 20, 0.5);
  }

  .item-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }

  .item-icon {
    flex: none;
    width: 42px;
    height: 42px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .item-icon--teal { background: rgba(19, 184, 154, 0.14); color: #13b89a; }
  .item-icon--purple { background: rgba(90, 30, 150, 0.14); color: #5a1e96; }
  .item-icon--navy { background: rgba(14, 42, 82, 0.12); color: #0e2a52; }

  .item-question {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 20px;
    color: rgba(52, 28, 101, 0.55);
    transition: color 0.3s;
  }
  .item.is-active .item-question {
    color: #2c2a35;
  }

  .item-answer {
    font-size: 15px;
    line-height: 1.6;
    color: #2c2a35;
    overflow: hidden;
    transition: max-height 0.5s ease-in-out, opacity 0.4s ease;
    max-height: 0;
    opacity: 0;
  }
  .item.is-active .item-answer {
    max-height: 120px;
    opacity: 1;
  }

  .hl--teal { color: #3be0bb; font-weight: 700; }
  .hl--ink { color: #341c65; font-weight: 700; }
  .hl--navy { color: rgba(13, 50, 86, 0.92); font-weight: 700; }

  @media (max-width: 1099.98px) {
    .hint-text--desktop {
      display: none;
    }
    .hint-text--mobile {
      display: inline;
    }
  }

  @media (max-width: 767.98px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .diagram {
      transform: scale(0.78);
      margin: -44px -44px -30px;
    }
    .list {
      width: 100%;
      max-width: 440px;
      margin: 0 auto;
    }
    .item:not(.is-active) {
      display: none;
    }
    .item.is-active .item-answer {
      max-height: 260px;
    }
  }
</style>
