---
---

<section class="cta-final">
  <div class="grain" aria-hidden="true"></div>
  <div class="ring" aria-hidden="true"></div>
  <div class="blob" aria-hidden="true"></div>

  <div class="content" data-reveal>
    <h2>¿Listo para transformar tu comunidad con la <span class="accent">metodología CLAP</span>?</h2>
    <p>
      Únete a la red de líderes que están convirtiendo los desafíos sociales de Latinoamérica en
      soluciones reales.
    </p>
    <div class="btns">
      <a class="btn btn--solid" href="/programas">
        Probar nuestros programas
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
      <a
        class="btn btn--ghost"
        href="https://api.whatsapp.com/send/?phone=3114481160&text&type=phone_number&app_absent=0&utm_source=ig"
        target="_blank"
        rel="noopener"
      >
        Conoce nuestros proyectos
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  import { attachReveal } from "../../scripts/reveal";

  const section = document.querySelector<HTMLElement>(".cta-final");
  if (section) {
    attachReveal(section, { threshold: 0.08, rootMargin: "0px 0px -4% 0px", repeat: false, duration: 700 });
  }
</script>

<style>
  .cta-final {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(75% 120% at 12% -5%, rgba(255, 255, 255, 0.95), transparent 58%),
      radial-gradient(85% 130% at 100% 112%, rgba(19, 184, 154, 0.32), transparent 60%),
      linear-gradient(150deg, #eef9f4 0%, #dcf2e8 52%, #c8ecde 100%);
    padding: 104px 48px 108px;
  }

  .grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    mix-blend-mode: overlay;
    opacity: 0.3;
    background-image: url("../../assets/images/grain.png");
    background-size: 600px;
  }

  .ring {
    position: absolute;
    right: -110px;
    top: -90px;
    width: 360px;
    height: 360px;
    border: 1.5px solid rgba(19, 184, 154, 0.28);
    border-radius: 50%;
    pointer-events: none;
  }
  .blob {
    position: absolute;
    left: -80px;
    bottom: -90px;
    width: 240px;
    height: 240px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.45);
    pointer-events: none;
  }

  .content {
    position: relative;
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 42px;
    letter-spacing: -0.025em;
    color: #341c65;
    line-height: 1.1;
    text-wrap: balance;
    max-width: 640px;
    margin: 0 auto;
  }
  h2 .accent {
    color: #13b89a;
  }

  p {
    font-size: 16.5px;
    line-height: 1.6;
    color: #5b5676;
    margin: 18px auto 0;
    max-width: 540px;
  }

  .btns {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
    margin-top: 34px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 15px;
    padding: 15px 30px;
    border-radius: 40px;
    text-decoration: none;
    transition: transform 0.25s;
  }
  .btn:hover {
    transform: translateY(-3px);
  }

  .btn--solid {
    background: #13b89a;
    color: #fff;
    box-shadow: 0 16px 40px -16px rgba(19, 184, 154, 0.6);
  }

  .btn--ghost {
    background: rgba(255, 255, 255, 0.55);
    color: #43197c;
    font-family: var(--font-display);
    font-weight: 700;
    border: 1px solid rgba(67, 25, 124, 0.25);
    transition: background 0.25s, transform 0.25s;
  }
  .btn--ghost:hover {
    background: #fff;
  }

  @media (max-width: 767.98px) {
    .cta-final {
      padding: 72px 22px;
    }
    h2 {
      font-size: 30px;
    }
  }
</style>
