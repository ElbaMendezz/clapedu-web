---
import { Image } from "astro:assets";
import territorioImage from "../../assets/images/metodologia-territorio.webp";
---

<section class="importancia">
  <div class="ring" aria-hidden="true"></div>
  <div class="blob" aria-hidden="true"></div>

  <div class="grid">
    <div class="col-text-top">
      <div class="eyebrow" data-reveal data-delay="0">
        <span class="eyebrow-dot" aria-hidden="true"></span>
        <span>¿por qué importa?</span>
      </div>
      <h2 data-reveal data-delay="120">
        Formamos líderes que <span class="accent">resuelven</span> desafíos sociales reales
      </h2>
      <p data-reveal data-delay="240">
        El centro de nuestra metodología radica en formar líderes capaces
        de enfrentar y resolver desafíos sociales complejos. No se trata
        solo de transmitir conocimientos, sino de desarrollar competencias
        diversificadas y adaptativas que les permitan actuar en entornos
        comunitarios y públicos.
      </p>
      <p data-reveal data-delay="360">
        La metodología <strong>CLAP</strong> está diseñada para empoderar
        a las personas, haciéndoles conscientes del impacto de sus
        acciones y preparándoles para contribuir de manera significativa
        a la sociedad.
      </p>
    </div>

    <div class="col-media" data-reveal="right">
      <div class="media" data-img-wipe-root>
        <Image src={territorioImage} alt="Líderes CLAP en territorio" width={900} height={880} class="photo" />
        <div class="scrim" aria-hidden="true"></div>
        <div class="wipe" data-img-wipe aria-hidden="true"></div>
      </div>
      <div class="float-card">
        <span class="float-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2 L13.5 9.5 L21 11 L13.5 12.5 L12 20 L10.5 12.5 L3 11 L10.5 9.5 Z"></path>
          </svg>
        </span>
        <div>
          <div class="float-title">Liderazgo en progreso</div>
          <div class="float-caption">Teoría + práctica en territorio</div>
        </div>
      </div>
    </div>

    <div class="stats" data-reveal data-delay="480">
      <div class="stat-card stat-card--purple" data-stat-card>
        <span class="stat-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="3" width="7" height="7" rx="1"></rect><rect x="3" y="14" width="7" height="7" rx="1"></rect><rect x="14" y="14" width="7" height="7" rx="1"></rect>
          </svg>
        </span>
        <div class="stat-body">
          <div class="stat-number"><span data-stat-num="4">0</span> fases</div>
          <div class="stat-caption">Explorar, Crear, Actuar y Resolver</div>
        </div>
      </div>
      <div class="stat-card stat-card--teal" data-stat-card>
        <span class="stat-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="6" cy="6" r="3"></circle><circle cx="18" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="18" r="3"></circle><path d="M9 6h6"></path><path d="M6 9v6"></path><path d="M18 9v6"></path><path d="M9 18h6"></path>
          </svg>
        </span>
        <div class="stat-body">
          <div class="stat-number"><span data-stat-num="4">0</span> Competencias</div>
          <div class="stat-caption">Que se entrelazan en cada fase</div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { attachReveal } from "../../scripts/reveal";
  import { attachStatCards } from "../../scripts/stat-cards";
  import { attachImgWipe } from "../../scripts/img-wipe";

  const section = document.querySelector<HTMLElement>(".importancia");
  if (section) {
    attachReveal(section, { threshold: 0.08, rootMargin: "0px 0px -4% 0px", repeat: false, duration: 700 });
    attachStatCards(section);
    attachImgWipe(section);
  }
</script>

<style>
  .importancia {
    position: relative;
    overflow: hidden;
    background: linear-gradient(160deg, #ffffff 0%, #f3f7f6 50%, #e7f4ef 100%);
    padding: 92px 48px 84px;
  }

  .ring {
    position: absolute;
    right: -120px;
    top: -80px;
    width: 360px;
    height: 360px;
    border: 2px solid rgba(19, 184, 154, 0.12);
    border-radius: 50%;
    pointer-events: none;
  }
  .blob {
    position: absolute;
    right: -60px;
    bottom: -80px;
    width: 260px;
    height: 260px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(19, 184, 154, 0.13), transparent 70%);
    filter: blur(30px);
    pointer-events: none;
  }

  .grid {
    position: relative;
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    grid-template-rows: auto auto;
    column-gap: 64px;
    align-items: center;
  }

  .col-text-top {
    grid-column: 1;
    grid-row: 1;
  }
  .col-media {
    margin-top: 24px;
    grid-column: 2;
    grid-row: 1 / 3;
  }
  .stats {
    /* margin-top: 40px; */
    grid-column: 1;
    grid-row: 2;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 16px;
    border: 1px solid rgba(59, 224, 187, 0.3);
    border-radius: 40px;
    margin-bottom: 18px;
    background: rgba(123, 77, 255, 0.08);
    font-family: var(--font-label);
    font-size: 13px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #43197c;
    font-weight: 400;
  }
  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #3be0bb;
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 40px;
    letter-spacing: -0.025em;
    color: #341c65;
    line-height: 1.1;
    text-wrap: balance;
  }
  h2 .accent {
    color: #13b89a;
  }

  p {
    font-size: 16px;
    line-height: 1.7;
    color: #6b6786;
    margin-top: 18px;
  }
  p:first-of-type {
    margin-top: 18px;
  }
  p + p {
    margin-top: 14px;
  }
  p strong {
    color: #43197c;
    font-weight: 800;
  }

  .stats {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 30px;
  }

  .stat-card {
    flex: 1;
    min-width: 150px;
    border: 1px solid rgba(67, 25, 124, 0.1);
    border-radius: 18px;
    padding: 20px 22px;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 14px;
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.55s ease, transform 0.55s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .stat-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .stat-card--purple {
    background-color: #f0edf5;
  }
  .stat-card--teal {
    border-color: rgba(19, 184, 154, 0.15);
    background-color: #e7f8f5;
    transition-delay: 0.18s;
  }

  .stat-icon {
    flex: none;
    width: 56px;
    height: 56px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .stat-card--purple .stat-icon {
    background: rgba(67, 25, 124, 0.08);
    color: #43197c;
  }
  .stat-card--teal .stat-icon {
    background: rgba(19, 184, 154, 0.1);
    color: #13b89a;
  }

  .stat-body {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .stat-number {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 20px;
    line-height: 1;
  }
  .stat-card--purple .stat-number {
    color: #43197c;
  }
  .stat-card--teal .stat-number {
    color: #13b89a;
  }
  .stat-caption {
    font-size: 13px;
    color: #8a85a0;
    line-height: 1.45;
  }

  .col-media {
    position: relative;
  }

  .media {
    position: relative;
    border-radius: 28px;
    overflow: hidden;
    box-shadow: 0 40px 80px -40px rgba(52, 28, 101, 0.55);
  }
  .media :global(.photo) {
    width: 100%;
    height: 440px;
    object-fit: cover;
    display: block;
    transform: scale(1.07);
    transition: transform 1.5s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .media.is-open :global(.photo) {
    transform: scale(1);
  }
  .scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(26, 15, 54, 0.6) 100%);
  }
  .wipe {
    position: absolute;
    inset: 0;
    z-index: 3;
    transform-origin: right center;
    background: linear-gradient(135deg, #43197c 0%, #13b89a 100%);
    pointer-events: none;
    transition: transform 0.95s cubic-bezier(0.77, 0, 0.18, 1);
  }
  .media.is-open .wipe {
    transform: scaleX(0);
  }

  .float-card {
    position: absolute;
    right: -26px;
    top: 28px;
    display: flex;
    align-items: center;
    gap: 13px;
    background: rgba(26, 16, 54, 0.28);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 20px;
    padding: 14px 20px;
    box-shadow: 0 20px 48px -20px rgba(0, 0, 0, 0.55);
    max-width: 280px;
  }
  .float-icon {
    flex: none;
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: linear-gradient(135deg, #43197c 0%, #13b89a 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #3be0bb;
    box-shadow: 0 8px 20px -8px rgba(19, 184, 154, 0.45);
  }
  .float-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 15px;
    color: #fff;
    line-height: 1.2;
  }
  .float-caption {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 12.5px;
    color: rgba(255, 255, 255, 0.65);
    margin-top: 2px;
  }

  @media (max-width: 1199.98px) {
    .stats {
      flex-direction: column;
    }
  }

  @media (max-width: 899.98px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .col-text-top,
    .col-media,
    .stats {
      grid-column: 1;
      grid-row: auto;
    }
    .col-text-top {
      order: 1;
    }
    .col-media {
      order: 2;
    }
    .stats {
      order: 3;
      margin-top: 30px;
      gap: 12px;
    }
  }

  @media (max-width: 767.98px) {
    .importancia {
      padding: 62px 22px;
    }
    h2 {
      font-size: 30px;
    }
    .float-card {
      right: 12px;
    }
  }
</style>
