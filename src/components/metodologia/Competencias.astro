  }
  .card-phases-label {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 12px;
  }
  .card-phases {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .phase-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 15px;
    border-radius: 30px;
    border: 1px solid transparent;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 13px;
    color: #fff;
  }
  .phase-chip-dot {
    width: 7px;
