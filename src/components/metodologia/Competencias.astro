  }
  .card-tag--analizar .card-label {
    color: #aab4ff;
  }
  .card-tag--articular {
    background: rgba(252, 120, 89, 0.18);
  }
  .card-tag--articular .card-dot {
    background: #fc7859;
  }
  .card-tag--articular .card-label {
    color: #ffab95;
  }
  .card-tag--gestionar {
