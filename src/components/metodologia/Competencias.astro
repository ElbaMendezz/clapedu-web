    width: 54px;
    height: 54px;
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.28);
    backdrop-filter: blur(8px);
  }

  /* ---------- diagram hover popup ---------- */
  .diagram-popup {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -48%) scale(0.95);
    z-index: 150;
    width: min(580px, 85vw);
    border-radius: 22px;
    overflow: hidden;
    box-shadow: 0 48px 100px -20px rgba(0, 0, 0, 0.75);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .diagram-popup.is-open {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
  .diagram-popup :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  @keyframes comp-pulse {
    0%,
    100% {
      opacity: 0.5;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.06);
    }
  }

  /* ---------- responsive ---------- */
  @media (max-width: 899.98px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767.98px) {
    .competencias {
      padding: 62px 22px;
    }
    h2 {
      font-size: 30px;
    }
  }
</style>
