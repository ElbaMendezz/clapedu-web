---
interface WhyCard {
  key: string;
  title: string;
  desc: string;
  iconPaths: string;
  highlighted?: boolean;
}

const cards: WhyCard[] = [
  {
    key: "aprendes-haciendo",
    title: "Aprendes haciendo",
    desc: "Trabaja sobre desafíos reales y aplica tus conocimientos desde el primer día.",
    iconPaths: '<path d="M14 2v6h6"></path><path d="M4 22V4a2 2 0 0 1 2-2h8l6 6v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2Z"></path><path d="m9 15 2 2 4-4"></path>',
  },
  {
    key: "resuelves-problemas",
    title: "Resuelves problemas reales",
    desc: "Participa en proyectos de consultoría desarrollados para organizaciones aliadas.",
    iconPaths: '<path d="M12 2v4M12 18v4M4.9 4.9l2.9 2.9M16.2 16.2l2.9 2.9M2 12h4M18 12h4M4.9 19.1l2.9-2.9M16.2 7.8l2.9-2.9"></path>',
  },
  {
    key: "mentoria",
    title: "Recibes mentoría especializada",
    desc: "Aprende junto a profesionales con experiencia en liderazgo social, gestión pública y desarrollo.",
    iconPaths:
      '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"></path>',
  },
  {
    key: "red-latam",
    title: "Construyes una red latinoamericana",
    desc: "Conéctate con estudiantes y profesionales de diferentes países y sectores.",
    iconPaths: '<circle cx="12" cy="12" r="10"></circle><path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20"></path>',
    highlighted: true,
  },
];
---

<section class="por-que-clap" data-screen-label="Por qué CLAP">
  <div class="cloud cloud--r1" aria-hidden="true"></div>
  <div class="cloud cloud--r2" aria-hidden="true"></div>
  <div class="cloud cloud--l1" aria-hidden="true"></div>
  <div class="ring ring--r" aria-hidden="true"></div>
  <div class="ring ring--l" aria-hidden="true"></div>
  <div class="grain" aria-hidden="true"></div>

  <div class="wrap">
    <div class="head">
      <div class="eyebrow" data-reveal data-delay="0">
        <span class="pulse-dot" aria-hidden="true">
          <span class="pulse-dot-ring"></span>
          <span class="pulse-dot-core"></span>
        </span>
        <span>La diferencia CLAP</span>
      </div>
      <h2 data-reveal data-delay="140" data-whyh2>¿Por qué estudiar en CLAP?</h2>
    </div>

    <div class="grid" data-whygrid>
      {cards.map((card, i) => (
        <div class:list={["why-card", `why-card--${card.key}`, { "why-card--highlighted": card.highlighted }]} data-reveal data-delay={String(i === 0 ? 0 : 80)}>
          <div class="why-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" set:html={card.iconPaths} />
          </div>
          <h3>{card.title}</h3>
          <p>{card.desc}</p>
        </div>
      ))}

      <div class="why-card why-card--wide" data-reveal data-delay="80" data-whywide>
        <div class="why-icon why-icon--wide">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#3BE0BB" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h7l-1 8 10-12h-7l1-8Z"></path></svg>
        </div>
        <div>
          <h3 data-whywideh3>Desarrollas experiencia en un solo semestre</h3>
          <p>Obtén herramientas aplicables y experiencia práctica en apenas 20 semanas.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { attachReveal } from "../../scripts/reveal";

  const section = document.querySelector<HTMLElement>(".por-que-clap");
  if (section) {
    attachReveal(section, {
      threshold: 0.15,
      rootMargin: "0px 0px -12% 0px",
      repeat: true,
      duration: 950,
      distanceY: 46,
      distanceX: 58,
      easing: "cubic-bezier(.16,.8,.3,1)",
    });
  }
</script>

<style>
  .por-que-clap {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(35deg, rgba(229, 38, 142, 0.3) 0%, rgba(46, 111, 224, 0.28) 16%, rgba(22, 164, 106, 0.2) 33%, transparent 54%),
      linear-gradient(-35deg, rgba(229, 38, 142, 0.3) 0%, rgba(46, 111, 224, 0.28) 16%, rgba(22, 164, 106, 0.2) 33%, transparent 54%),
      #ffffff;
    background-size: 180% 180%, 180% 180%, 100% 100%;
    animation: pe-grad 22s ease-in-out infinite;
    padding: 96px 48px 100px;
  }
  @keyframes pe-grad {
    0% { background-position: 0% 50%, 0% 50%, 0 0; }
    50% { background-position: 100% 50%, 100% 50%, 0 0; }
    100% { background-position: 0% 50%, 0% 50%, 0 0; }
  }

  .cloud {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }
  .cloud--r1 {
    right: -150px;
    top: -130px;
    width: 540px;
    height: 540px;
    background: radial-gradient(circle, rgba(22, 164, 106, 0.22), transparent 62%);
    filter: blur(74px);
    animation: pe-drift-2 22s ease-in-out infinite;
  }
  .cloud--r2 {
    right: -70px;
    bottom: -170px;
    width: 470px;
    height: 470px;
    background: radial-gradient(circle, rgba(46, 111, 224, 0.2), transparent 62%);
    filter: blur(70px);
    animation: pe-drift-3 26s ease-in-out infinite;
  }
  .cloud--l1 {
    left: -150px;
    top: -130px;
    width: 540px;
    height: 540px;
    background: radial-gradient(circle, rgba(229, 38, 142, 0.2), transparent 62%);
    filter: blur(70px);
    animation: pe-drift-1 23s ease-in-out infinite;
  }
  @keyframes pe-drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(110px, -70px) scale(1.18); }
  }
  @keyframes pe-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-90px, 60px) scale(1.22); }
  }
  @keyframes pe-drift-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(80px, 90px) scale(0.88); }
  }

  .ring {
    position: absolute;
    bottom: -100px;
    width: 500px;
    height: 500px;
    border: 1.5px solid rgba(52, 28, 101, 0.08);
    border-radius: 50%;
    pointer-events: none;
  }
  .ring--r {
    right: -120px;
  }
  .ring--l {
    left: -120px;
  }

  .grain {
    position: absolute;
    inset: 0;
    background-image: url("../../assets/images/noise-texture.png");
    background-size: auto;
    opacity: 0.3;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  .wrap {
    position: relative;
    z-index: 1;
    max-width: 1240px;
    margin: 0 auto;
  }

  .head {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 46px;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 8px 17px;
    border: 1px solid rgba(19, 184, 154, 0.4);
    border-radius: 40px;
    background: rgba(19, 184, 154, 0.1);
    font-family: var(--font-label);
    font-size: 12.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #341c65;
    font-weight: 400;
  }
  .pulse-dot {
    position: relative;
    display: flex;
    width: 8px;
    height: 8px;
  }
  .pulse-dot-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #13b89a;
    animation: pe-pulse 2.2s ease-out infinite;
  }
  .pulse-dot-core {
    position: relative;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #13b89a;
  }
  @keyframes pe-pulse {
    0% { transform: scale(0.6); opacity: 0.5; }
    80% { opacity: 0; }
    100% { transform: scale(1.7); opacity: 0; }
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 44px;
    color: #341c65;
    line-height: 1.06;
    letter-spacing: -0.026em;
    margin-top: 12px;
    text-wrap: balance;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .why-card {
    position: relative;
    overflow: hidden;
    grid-column: span 1;
    background: #fff;
    border: 1px solid rgba(52, 28, 101, 0.08);
    border-radius: 22px;
    padding: 30px 28px;
    box-shadow: 0 26px 56px -34px rgba(52, 28, 101, 0.4);
    transition: transform 0.35s, box-shadow 0.35s, background 0.35s, border-color 0.35s;
  }
  .why-card:hover {
    /* !important necesario: la tarjeta lleva data-reveal, y reveal.ts fija
       transform inline (mayor especificidad que cualquier regla de hoja de
       estilos) una vez revelada — sin esto el hover nunca podría cambiarlo. */
    transform: translateY(-8px) scale(1.02) !important;
    box-shadow: 0 42px 84px -36px rgba(52, 28, 101, 0.55);
  }
  .why-card:hover h3,
  .why-card:hover p {
    color: #fff;
  }
  .why-card--highlighted {
    border-color: rgba(59, 224, 187, 0.35);
    box-shadow: 0 26px 56px -34px rgba(19, 184, 154, 0.4);
  }
  .why-card--aprendes-haciendo:hover,
  .why-card--red-latam:hover {
    background: linear-gradient(120deg, #0e9e84, #13b89a);
    border-color: transparent;
  }
  .why-card--resuelves-problemas:hover {
    background: linear-gradient(120deg, #b81570, #e5268e);
    border-color: transparent;
  }
  .why-card--mentoria:hover {
    background: linear-gradient(120deg, #1a4fb0, #2e6fe0);
    border-color: transparent;
  }

  .why-icon {
    width: 52px;
    height: 52px;
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    transition: transform 0.35s, background 0.35s;
  }
  .why-card--aprendes-haciendo .why-icon {
    background: rgba(59, 224, 187, 0.16);
    color: #3be0bb;
  }
  .why-card--resuelves-problemas .why-icon {
    background: rgba(229, 38, 142, 0.18);
    color: #ff5aa8;
  }
  .why-card--mentoria .why-icon {
    background: rgba(46, 111, 224, 0.2);
    color: #6fa0ff;
  }
  .why-card--red-latam .why-icon {
    background: rgba(59, 224, 187, 0.2);
    color: #3be0bb;
  }
  .why-card:hover .why-icon {
    transform: scale(1.08) rotate(-4deg);
    background: rgba(255, 255, 255, 0.2);
  }

  .why-card h3 {
    position: relative;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 20px;
    color: #341c65;
    line-height: 1.2;
    transition: color 0.35s;
  }
  .why-card p {
    position: relative;
    font-size: 14.5px;
    line-height: 1.6;
    color: #6b6786;
    margin-top: 11px;
    transition: color 0.35s;
  }

  /* ---------- wide card ---------- */
  .why-card--wide {
    grid-column: span 2;
    display: flex;
    align-items: center;
    gap: 28px;
    background: linear-gradient(120deg, #43197c, #5a2b9c);
    border: 1px solid rgba(255, 255, 255, 0.14);
  }
  .why-icon--wide {
    flex: none;
    width: 64px;
    height: 64px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.16);
  }
  .why-card--wide h3 {
    font-size: 22px;
    color: #fff;
    line-height: 1.15;
  }
  .why-card--wide p {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.8);
    margin-top: 9px;
  }

  /* ---------- responsive ---------- */
  @media (max-width: 979.98px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 719.98px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .why-card--wide {
      grid-column: span 1;
    }
  }
  @media (max-width: 559.98px) {
    .por-que-clap {
      padding-top: 48px;
      padding-bottom: 52px;
    }
    h2 {
      font-size: 28px;
    }
    .why-card--wide h3 {
      font-size: 18px;
    }
  }
</style>
