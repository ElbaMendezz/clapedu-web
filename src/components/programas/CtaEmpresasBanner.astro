---
import { Image } from "astro:assets";
import bgParaEmpresas from "../../assets/images/programas-bg-para-empresas.webp";
---

<section class="cta-empresas" data-screen-label="Para empresas">
  <Image src={bgParaEmpresas} alt="" width={1800} height={780} class="bg-photo" />
  <div class="blob blob--violet" aria-hidden="true"></div>
  <div class="blob blob--teal" aria-hidden="true"></div>
  <div class="grain" aria-hidden="true"></div>

  <div class="wrap">
    <div class="eyebrow" data-reveal>
      <span class="pulse-dot" aria-hidden="true">
        <span class="pulse-dot-ring"></span>
        <span class="pulse-dot-core"></span>
      </span>
      <span>Para empresas u organizaciones</span>
    </div>
    <h2 data-reveal data-emph2>¿Representas una empresa u organización?</h2>
    <p data-reveal>
      Conoce los beneficios de los programas especializados diseñados para vincular a tu equipo con el
      talento de CLAP.
    </p>
    <a class="cta-link" href="#" data-go="empresas" data-reveal>
      Conocer los programas con beneficios
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
    </a>
  </div>
</section>

<script>
  import { attachReveal } from "../../scripts/reveal";

  const section = document.querySelector<HTMLElement>(".cta-empresas");
  if (section) {
    attachReveal(section, {
      threshold: 0.15,
      rootMargin: "0px 0px -12% 0px",
      repeat: true,
      duration: 950,
      distanceY: 46,
      distanceX: 58,
      easing: "cubic-bezier(.16,.8,.3,1)",
    });
    // El click en el CTA data-go="empresas" ya lo maneja el attachTrackToggle(document)
    // global de Hero.astro (los <script type="module"> se difieren hasta que el DOM
    // completo está parseado, así que su querySelectorAll("[data-go]") ya alcanza
    // este botón sin necesidad de una segunda instancia scopeada acá).
  }
</script>

<style>
  .cta-empresas {
    position: relative;
    overflow: hidden;
    background: linear-gradient(120deg, #341c65 0%, #7b4dff 40%, #13b89a 100%);
    background-size: 220% 220%;
    animation: pe-grad-diag 20s ease infinite;
    padding: 82px 48px 86px;
  }
  @keyframes pe-grad-diag {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .bg-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.16;
    mix-blend-mode: luminosity;
    pointer-events: none;
  }
  .blob {
    position: absolute;
    width: 520px;
    height: 520px;
    border-radius: 50%;
    pointer-events: none;
  }
  .blob--violet {
    right: -140px;
    top: -120px;
    background: radial-gradient(circle, rgba(123, 77, 255, 0.42), transparent 62%);
    filter: blur(72px);
    animation: pe-drift-2 22s ease-in-out infinite;
  }
  .blob--teal {
    left: -140px;
    bottom: -140px;
    background: radial-gradient(circle, rgba(19, 184, 154, 0.4), transparent 62%);
    filter: blur(72px);
    animation: pe-drift-1 26s ease-in-out infinite;
  }
  @keyframes pe-drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(110px, -70px) scale(1.18); }
  }
  @keyframes pe-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-90px, 60px) scale(1.22); }
  }

  .grain {
    position: absolute;
    inset: 0;
    background-image: url("../../assets/images/noise-texture.webp");
    background-size: cover;
    opacity: 0.28;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  .wrap {
    position: relative;
    z-index: 1;
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 8px 17px;
    border: 1px solid rgba(59, 224, 187, 0.42);
    border-radius: 40px;
    background: rgba(59, 224, 187, 0.12);
    backdrop-filter: blur(6px);
    font-family: var(--font-label);
    font-size: 12.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #3be0bb;
    font-weight: 400;
  }
  .pulse-dot {
    position: relative;
    display: flex;
    width: 8px;
    height: 8px;
  }
  .pulse-dot-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #3be0bb;
    animation: pe-pulse 2.2s ease-out infinite;
  }
  .pulse-dot-core {
    position: relative;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #3be0bb;
  }
  @keyframes pe-pulse {
    0% { transform: scale(0.6); opacity: 0.5; }
    80% { opacity: 0; }
    100% { transform: scale(1.7); opacity: 0; }
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 44px;
    color: #fff;
    line-height: 1.06;
    letter-spacing: -0.026em;
    margin-top: 14px;
    text-wrap: balance;
  }
  .wrap p {
    font-size: 16px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.78);
    margin-top: 16px;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-link {
    margin-top: 30px;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: #fff;
    color: #341c65;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 15px;
    padding: 16px 30px;
    border-radius: 44px;
    text-decoration: none;
    transition: transform 0.25s;
  }
  .cta-link:hover {
    transform: translateY(-2px);
  }

  @media (max-width: 559.98px) {
    .cta-empresas {
      padding: 46px 48px 48px;
    }
    h2 {
      font-size: 32px;
    }
  }
</style>
