---
interface StageItem {
  label: string;
  iconPaths: string;
}

interface Stage {
  key: string;
  eyebrow: string;
  title: string;
  desc: string;
  items: StageItem[];
}

const stages: Stage[] = [
  {
    key: "formacion",
    eyebrow: "Etapa 1",
    title: "Formación especializada",
    desc: "Fortalece tus conocimientos con clases en vivo, casos reales y herramientas aplicadas, junto a docentes con trayectoria en liderazgo social y desarrollo.",
    items: [
      {
        label: "Clases en vivo",
        iconPaths: '<path d="m22 8-6 4 6 4V8Z"></path><rect x="2" y="6" width="14" height="12" rx="2"></rect>',
      },
      {
        label: "Casos reales",
        iconPaths: '<rect x="2" y="7" width="20" height="14" rx="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>',
      },
      {
        label: "Herramientas aplicadas",
        iconPaths:
          '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2 2 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94Z"></path>',
      },
    ],
  },
  {
    key: "consultoria",
    eyebrow: "Etapa 2",
    title: "Consultoría real",
    desc: "Trabaja durante varias semanas resolviendo un desafío de una organización, junto a un equipo multidisciplinario y el acompañamiento de un mentor CLAP.",
    items: [
      {
        label: "Desafío de una organización",
        iconPaths: '<path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path><path d="M4 22v-7"></path>',
      },
      {
        label: "Equipo multidisciplinario",
        iconPaths:
          '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"></path>',
      },
      {
        label: "Acompañamiento de un mentor",
        iconPaths:
          '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="m16 11 2 2 4-4"></path>',
      },
    ],
  },
];
---

<section class="asi-aprenderas" data-screen-label="Así aprenderás">
  <div class="cloud cloud--r1" aria-hidden="true"></div>
  <div class="cloud cloud--r2" aria-hidden="true"></div>
  <div class="cloud cloud--r3" aria-hidden="true"></div>
  <div class="cloud cloud--l1" aria-hidden="true"></div>
  <div class="cloud cloud--l2" aria-hidden="true"></div>
  <div class="cloud cloud--l3" aria-hidden="true"></div>
  <div class="ring ring--r" aria-hidden="true"></div>
  <div class="ring ring--l" aria-hidden="true"></div>
  <div class="grain" aria-hidden="true"></div>

  <div class="wrap">
    <div class="head" data-reveal>
      <div class="eyebrow">
        <span class="pulse-dot" aria-hidden="true">
          <span class="pulse-dot-ring"></span>
          <span class="pulse-dot-core"></span>
        </span>
        <span>20 semanas · 2 etapas</span>
      </div>
      <h2 data-aprendh2>Así aprenderás</h2>
      <p>
        Vivirás una experiencia de formación intensiva dividida en dos etapas que se conectan: primero
        construyes la base, luego la aplicas resolviendo un desafío real.
      </p>
    </div>

    <div class="grid" data-asigrid>
      {stages.map((stage, i) => (
        <div class={`stage-card stage-card--${stage.key}`} data-reveal={i === 0 ? "left" : "right"} data-delay={i === 0 ? "0" : "360"}>
          <div class="stage-head">
            <div class="stage-ring" aria-hidden="true"></div>
            <span class="stage-eyebrow">{stage.eyebrow}</span>
            <h3>{stage.title}</h3>
          </div>
          <div class="stage-body">
            <p>{stage.desc}</p>
            <div class="stage-items">
              {stage.items.map((item, k) => (
                <div class="stage-item" data-reveal data-delay={String(k * 90)}>
                  <span class="stage-item-icon">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" set:html={item.iconPaths} />
                  </span>
                  <span class="stage-item-label">{item.label}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { attachReveal } from "../../scripts/reveal";

  const section = document.querySelector<HTMLElement>(".asi-aprenderas");
  if (section) {
    attachReveal(section, {
      threshold: 0.15,
      rootMargin: "0px 0px -12% 0px",
      repeat: true,
      duration: 950,
      distanceY: 46,
      distanceX: 58,
      easing: "cubic-bezier(.16,.8,.3,1)",
    });
  }
</script>

<style>
  .asi-aprenderas {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(35deg, rgba(229, 38, 142, 0.3) 0%, rgba(46, 111, 224, 0.28) 16%, rgba(22, 164, 106, 0.2) 33%, transparent 54%),
      linear-gradient(-35deg, rgba(229, 38, 142, 0.3) 0%, rgba(46, 111, 224, 0.28) 16%, rgba(22, 164, 106, 0.2) 33%, transparent 54%),
      #ffffff;
    background-size: 180% 180%, 180% 180%, 100% 100%;
    animation: pe-grad 22s ease-in-out infinite;
    padding: 96px 48px 100px;
  }
  @keyframes pe-grad {
    0% { background-position: 0% 50%, 0% 50%, 0 0; }
    50% { background-position: 100% 50%, 100% 50%, 0 0; }
    100% { background-position: 0% 50%, 0% 50%, 0 0; }
  }

  .cloud {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }
  .cloud--r1 {
    right: -150px;
    top: -130px;
    width: 540px;
    height: 540px;
    background: radial-gradient(circle, rgba(22, 164, 106, 0.22), transparent 62%);
    filter: blur(74px);
    animation: pe-drift-2 22s ease-in-out infinite;
  }
  .cloud--r2 {
    right: -70px;
    bottom: -170px;
    width: 470px;
    height: 470px;
    background: radial-gradient(circle, rgba(46, 111, 224, 0.2), transparent 62%);
    filter: blur(70px);
    animation: pe-drift-3 26s ease-in-out infinite;
  }
  .cloud--r3 {
    right: 6%;
    top: 30%;
    width: 360px;
    height: 360px;
    background: radial-gradient(circle, rgba(229, 38, 142, 0.14), transparent 62%);
    filter: blur(64px);
    animation: pe-drift-1 30s ease-in-out infinite;
  }
  .cloud--l1 {
    left: -150px;
    top: -130px;
    width: 540px;
    height: 540px;
    background: radial-gradient(circle, rgba(22, 164, 106, 0.22), transparent 62%);
    filter: blur(74px);
    animation: pe-drift-1 23s ease-in-out infinite;
  }
  .cloud--l2 {
    left: -70px;
    bottom: -170px;
    width: 470px;
    height: 470px;
    background: radial-gradient(circle, rgba(229, 38, 142, 0.2), transparent 62%);
    filter: blur(70px);
    animation: pe-drift-2 27s ease-in-out infinite;
  }
  .cloud--l3 {
    left: 6%;
    top: 30%;
    width: 360px;
    height: 360px;
    background: radial-gradient(circle, rgba(46, 111, 224, 0.14), transparent 62%);
    filter: blur(64px);
    animation: pe-drift-3 31s ease-in-out infinite;
  }
  @keyframes pe-drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(110px, -70px) scale(1.18); }
  }
  @keyframes pe-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-90px, 60px) scale(1.22); }
  }
  @keyframes pe-drift-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(80px, 90px) scale(0.88); }
  }

  .ring {
    position: absolute;
    bottom: -100px;
    width: 500px;
    height: 500px;
    border: 1.5px solid rgba(52, 28, 101, 0.08);
    border-radius: 50%;
    pointer-events: none;
  }
  .ring--r {
    right: -120px;
  }
  .ring--l {
    left: -120px;
  }

  .grain {
    position: absolute;
    inset: 0;
    background-image: url("../../assets/images/noise-texture.webp");
    background-size: auto;
    opacity: 0.3;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  .wrap {
    position: relative;
    z-index: 1;
    max-width: 1180px;
    margin: 0 auto;
  }

  .head {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 12px;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 8px 17px;
    border: 1px solid rgba(19, 184, 154, 0.4);
    border-radius: 40px;
    background: rgba(19, 184, 154, 0.1);
    font-family: var(--font-label);
    font-size: 12.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #341c65;
    font-weight: 400;
  }
  .pulse-dot {
    position: relative;
    display: flex;
    width: 8px;
    height: 8px;
  }
  .pulse-dot-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #13b89a;
    animation: pe-pulse 2.2s ease-out infinite;
  }
  .pulse-dot-core {
    position: relative;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #13b89a;
  }
  @keyframes pe-pulse {
    0% { transform: scale(0.6); opacity: 0.5; }
    80% { opacity: 0; }
    100% { transform: scale(1.7); opacity: 0; }
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 44px;
    color: #341c65;
    line-height: 1.06;
    letter-spacing: -0.026em;
    margin-top: 12px;
    text-wrap: balance;
  }
  .head p {
    font-size: 16px;
    line-height: 1.6;
    color: #6b6786;
    margin-top: 16px;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
    align-items: stretch;
    margin-top: 48px;
  }

  .stage-card {
    background: #fff;
    border-radius: 26px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .stage-card--formacion {
    border: 1px solid rgba(229, 38, 142, 0.16);
    box-shadow: 0 40px 90px -46px rgba(229, 38, 142, 0.5);
  }
  .stage-card--consultoria {
    border: 1px solid rgba(46, 111, 224, 0.16);
    box-shadow: 0 40px 90px -46px rgba(46, 111, 224, 0.5);
  }

  .stage-head {
    position: relative;
    overflow: hidden;
    background: linear-gradient(120deg, #e5268e 0%, #2e6fe0 52%, #16a46a 100%);
    background-size: 200% 200%;
    animation: pe-grad-head 16s ease infinite;
    padding: 30px 34px;
    color: #fff;
  }
  @keyframes pe-grad-head {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  .stage-ring {
    position: absolute;
    right: -40px;
    top: -40px;
    width: 150px;
    height: 150px;
    border: 1.5px solid rgba(255, 255, 255, 0.16);
    border-radius: 50%;
    pointer-events: none;
  }
  .stage-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-label);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
  }
  .stage-head h3 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 26px;
    line-height: 1.12;
    margin-top: 8px;
    letter-spacing: -0.02em;
  }

  .stage-body {
    padding: 28px 34px 32px;
    flex: 1;
  }
  .stage-body > p {
    font-size: 15.5px;
    line-height: 1.6;
    color: #3a2c52;
  }

  .stage-items {
    display: flex;
    flex-direction: column;
    gap: 11px;
    margin-top: 22px;
  }
  .stage-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    border-radius: 14px;
  }
  .stage-card--formacion .stage-item {
    background: #fdf1f8;
  }
  .stage-card--consultoria .stage-item {
    background: #eef3fd;
  }
  .stage-item-icon {
    flex: none;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .stage-card--formacion .stage-item-icon {
    background: #e5268e;
  }
  .stage-card--consultoria .stage-item-icon {
    background: #2e6fe0;
  }
  .stage-item-label {
    font-size: 14.5px;
    color: #3a2c52;
    font-weight: 600;
  }

  /* ---------- responsive ---------- */
  @media (max-width: 819.98px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 559.98px) {
    .asi-aprenderas {
      padding-top: 48px;
      padding-bottom: 52px;
    }
    h2 {
      font-size: 28px;
    }
    .grid {
      margin-top: 24px;
    }
    .stage-head {
      padding: 18px 24px 20px;
    }
    .stage-head h3 {
      font-size: 22px;
    }
  }
</style>
