---
const FORM_URL = "https://docs.google.com/forms/d/e/1FAIpQLSdUwLTO1qOGkCl3WfXqNKyCaSOjeHKgaUvZsEBmrs-jhco3ZQ/viewform";
const WHATSAPP_URL = "https://api.whatsapp.com/send/?phone=573114481160&text&type=phone_number&app_absent=0";
---

<section class="cta-final" data-screen-label="CTA Final">
  <div class="ring" aria-hidden="true"></div>
  <div class="blob" aria-hidden="true"></div>

  <div class="content" data-reveal>
    <h2 data-ctafinalh2>
      Más que una formación: una <span class="accent">oportunidad de crecimiento profesional</span>
    </h2>
    <p>
      Únete a la red de líderes que están convirtiendo los desafíos sociales de Latinoamérica en
      soluciones reales. Tu cupo empieza con un formulario.
    </p>
    <div class="btns">
      <a class="btn btn--solid" href={FORM_URL} target="_blank" rel="noopener">
        Quiero inscribirme
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
      </a>
      <a class="btn btn--ghost" href={WHATSAPP_URL} target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="wa-icon"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-1.219zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.078 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"></path></svg>
        Hablar con alguien por WhatsApp
      </a>
    </div>
  </div>
</section>

<script>
  import { attachReveal } from "../../scripts/reveal";

  const section = document.querySelector<HTMLElement>(".cta-final");
  if (section) {
    attachReveal(section, {
      threshold: 0.15,
      rootMargin: "0px 0px -12% 0px",
      repeat: true,
      duration: 950,
      distanceY: 46,
      distanceX: 58,
      easing: "cubic-bezier(.16,.8,.3,1)",
    });
  }
</script>

<style>
  .cta-final {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(80% 130% at 12% -10%, rgba(255, 255, 255, 0.95), transparent 58%),
      radial-gradient(90% 130% at 100% 112%, rgba(19, 184, 154, 0.3), transparent 60%),
      linear-gradient(150deg, #eef9f4 0%, #dcf2e8 52%, #c8ecde 100%);
    padding: 104px 48px 108px;
  }

  .ring {
    position: absolute;
    right: -110px;
    top: -90px;
    width: 360px;
    height: 360px;
    border: 1.5px solid rgba(19, 184, 154, 0.28);
    border-radius: 50%;
    pointer-events: none;
  }
  .blob {
    position: absolute;
    left: -80px;
    bottom: -90px;
    width: 240px;
    height: 240px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.45);
    pointer-events: none;
  }

  .content {
    position: relative;
    max-width: 780px;
    margin: 0 auto;
    text-align: center;
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 46px;
    letter-spacing: -0.026em;
    color: #341c65;
    line-height: 1.08;
    text-wrap: balance;
  }
  h2 .accent {
    color: #13b89a;
  }

  .content p {
    font-size: 17px;
    line-height: 1.6;
    color: #5b5676;
    margin-top: 20px;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .btns {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
    margin-top: 34px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 16px;
    padding: 17px 34px;
    border-radius: 44px;
    text-decoration: none;
    transition: transform 0.25s, background 0.25s;
  }

  .btn--solid {
    background: #13b89a;
    color: #fff;
    box-shadow: 0 18px 44px -16px rgba(19, 184, 154, 0.6);
  }
  .btn--solid:hover {
    transform: translateY(-3px);
  }

  .btn--ghost {
    background: rgba(255, 255, 255, 0.6);
    color: #43197c;
    border: 1px solid rgba(67, 25, 124, 0.2);
    padding: 17px 32px;
  }
  .btn--ghost:hover {
    background: #fff;
    transform: translateY(-3px);
  }
  .wa-icon {
    flex: none;
  }

  /* ---------- responsive ---------- */
  @media (max-width: 559.98px) {
    .cta-final {
      padding-top: 52px;
      padding-bottom: 56px;
    }
    h2 {
      font-size: 30px;
    }
  }
</style>
