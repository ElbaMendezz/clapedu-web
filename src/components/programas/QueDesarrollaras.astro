---
import { Image } from "astro:assets";
import bgDesarrollaras from "../../assets/images/programas-bg-desarrollaras.webp";

interface Skill {
  key: string;
  label: string;
  iconPaths: string;
  wide?: boolean;
}

const skills: Skill[] = [
  {
    key: "liderazgo",
    label: "Liderazgo",
    iconPaths: '<circle cx="12" cy="8" r="6"></circle><path d="M15.5 13.5 17 22l-5-3-5 3 1.5-8.5"></path>',
    wide: true,
  },
  {
    key: "gestion-proyectos",
    label: "Gestión de proyectos",
    iconPaths: '<rect width="8" height="4" x="8" y="2" rx="1"></rect><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><path d="M9 12h6M9 16h4"></path>',
  },
  {
    key: "pensamiento-estrategico",
    label: "Pensamiento estratégico",
    iconPaths: '<circle cx="12" cy="12" r="9"></circle><circle cx="12" cy="12" r="5"></circle><circle cx="12" cy="12" r="1.5"></circle>',
  },
  {
    key: "analisis",
    label: "Análisis de problemas complejos",
    iconPaths: '<circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path>',
  },
  {
    key: "trabajo-colaborativo",
    label: "Trabajo colaborativo",
    iconPaths: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"></path>',
  },
  {
    key: "innovacion-social",
    label: "Innovación social",
    iconPaths: '<path d="M9 18h6M10 22h4M12 2a7 7 0 0 0-4 12.7c.6.5 1 1.3 1 2.1h6c0-.8.4-1.6 1-2.1A7 7 0 0 0 12 2Z"></path>',
  },
  {
    key: "gestion-desarrollo",
    label: "Gestión del desarrollo",
    iconPaths: '<path d="M3 3v18h18"></path><path d="m19 9-5 5-4-4-3 3"></path>',
  },
];
---

<section class="que-desarrollaras" data-screen-label="Qué desarrollarás">
  <Image src={bgDesarrollaras} alt="" width={1800} height={780} class="bg-photo" />
  <div class="blob blob--blue" aria-hidden="true"></div>
  <div class="blob blob--pink" aria-hidden="true"></div>
  <div class="grain" aria-hidden="true"></div>

  <div class="wrap">
    <div class="head" data-reveal>
      <div class="eyebrow">
        <span class="pulse-dot" aria-hidden="true">
          <span class="pulse-dot-ring"></span>
          <span class="pulse-dot-core"></span>
        </span>
        <span>Competencias que te llevas</span>
      </div>
      <h2>¿Qué desarrollarás?</h2>
      <p>Siete competencias transversales que aplicarás en cualquier ruta y en cualquier organización.</p>
    </div>

    <div class="grid">
      {skills.map((skill, i) => (
        <div class:list={["skill-card", { "skill-card--wide": skill.wide }]} data-reveal data-delay={String(i * 70)}>
          <span class={`skill-icon skill-icon--${skill.key}`}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" set:html={skill.iconPaths} />
          </span>
          <span class="skill-label">{skill.label}</span>
        </div>
      ))}
    </div>

    <div class="cta-wrap" data-reveal>
      <a
        class="cta-link"
        href="https://docs.google.com/forms/d/e/1FAIpQLSdUwLTO1qOGkCl3WfXqNKyCaSOjeHKgaUvZsEBmrs-jhco3ZQ/viewform"
        target="_blank"
        rel="noopener"
      >
        Quiero desarrollar estas competencias
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
      </a>
    </div>
  </div>
</section>

<script>
  import { attachReveal } from "../../scripts/reveal";

  const section = document.querySelector<HTMLElement>(".que-desarrollaras");
  if (section) {
    attachReveal(section, {
      threshold: 0.15,
      rootMargin: "0px 0px -12% 0px",
      repeat: true,
      duration: 950,
      distanceY: 46,
      distanceX: 58,
      easing: "cubic-bezier(.16,.8,.3,1)",
    });
  }
</script>

<style>
  .que-desarrollaras {
    position: relative;
    overflow: hidden;
    background: linear-gradient(120deg, #14307e 0%, #2e6fe0 32%, #9c2f7a 68%, #e5268e 100%);
    background-size: 220% 220%;
    animation: pe-grad 20s ease infinite;
    padding: 96px 48px 100px;
  }
  @keyframes pe-grad {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .bg-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.16;
    mix-blend-mode: luminosity;
    pointer-events: none;
  }
  .blob {
    position: absolute;
    width: 520px;
    height: 520px;
    border-radius: 50%;
    pointer-events: none;
  }
  .blob--blue {
    right: -140px;
    top: -120px;
    background: radial-gradient(circle, rgba(46, 111, 224, 0.4), transparent 62%);
    filter: blur(72px);
    animation: pe-drift-2 22s ease-in-out infinite;
  }
  .blob--pink {
    left: -140px;
    bottom: -140px;
    background: radial-gradient(circle, rgba(229, 38, 142, 0.38), transparent 62%);
    filter: blur(72px);
    animation: pe-drift-1 26s ease-in-out infinite;
  }
  @keyframes pe-drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(110px, -70px) scale(1.18); }
  }
  @keyframes pe-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-90px, 60px) scale(1.22); }
  }

  .grain {
    position: absolute;
    inset: 0;
    background-image: url("../../assets/images/noise-texture.webp");
    background-size: cover;
    opacity: 0.28;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  .wrap {
    position: relative;
    z-index: 1;
    max-width: 1180px;
    margin: 0 auto;
  }

  .head {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 46px;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 8px 17px;
    border: 1px solid rgba(23, 255, 132, 0.42);
    border-radius: 40px;
    background: rgba(23, 255, 132, 0.1);
    backdrop-filter: blur(6px);
    font-family: var(--font-label);
    font-size: 12.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #17ff84;
    font-weight: 400;
  }
  .pulse-dot {
    position: relative;
    display: flex;
    width: 8px;
    height: 8px;
  }
  .pulse-dot-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #17ff84;
    animation: pe-pulse 2.2s ease-out infinite;
  }
  .pulse-dot-core {
    position: relative;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #17ff84;
  }
  @keyframes pe-pulse {
    0% { transform: scale(0.6); opacity: 0.5; }
    80% { opacity: 0; }
    100% { transform: scale(1.7); opacity: 0; }
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 44px;
    color: #fff;
    line-height: 1.06;
    letter-spacing: -0.026em;
    margin-top: 12px;
    text-wrap: balance;
  }
  .head p {
    font-size: 16px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.72);
    margin-top: 16px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .skill-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 14px;
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.04));
    backdrop-filter: blur(10px);
    border-radius: 20px;
    padding: 22px 22px;
  }
  .skill-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 20px;
    padding: 1.5px;
    background: linear-gradient(140deg, rgba(255, 255, 255, 0.75), rgba(255, 255, 255, 0.18));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }
  .skill-card--wide {
    grid-column: span 2;
  }
  .skill-icon {
    flex: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .skill-icon--liderazgo {
    background: #3be0bb;
  }
  .skill-icon--gestion-proyectos {
    background: #ff5aa8;
  }
  .skill-icon--pensamiento-estrategico {
    background: #3be0bb;
  }
  .skill-icon--analisis {
    background: #6fa0ff;
  }
  .skill-icon--trabajo-colaborativo {
    background: #f5a623;
  }
  .skill-icon--innovacion-social {
    background: #3ecb8a;
  }
  .skill-icon--gestion-desarrollo {
    background: #a98cff;
  }
  .skill-label {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15.5px;
    color: #fff;
    line-height: 1.2;
  }

  .cta-wrap {
    display: flex;
    justify-content: center;
    margin-top: 46px;
  }
  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #3be0bb;
    color: #0c1f1a;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 16px;
    padding: 17px 34px;
    border-radius: 44px;
    text-decoration: none;
    box-shadow: 0 18px 44px -16px rgba(59, 224, 187, 0.5);
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .cta-link:hover {
    transform: translateY(-3px);
    box-shadow: 0 24px 54px -16px rgba(59, 224, 187, 0.7);
  }

  /* ---------- responsive ---------- */
  @media (max-width: 979.98px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 559.98px) {
    .que-desarrollaras {
      padding-top: 46px;
      padding-bottom: 52px;
    }
    .head {
      margin-bottom: 26px;
    }
    .grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 9px;
    }
    .skill-card {
      flex: 0 0 auto;
      padding: 8px 15px 8px 8px;
      gap: 9px;
    }
    .skill-card--wide {
      grid-column: unset;
    }
    .skill-icon {
      width: 28px;
      height: 28px;
    }
    .skill-icon svg {
      width: 15px;
      height: 15px;
    }
    .skill-label {
      font-size: 13px;
    }
    .cta-wrap {
      margin-top: 28px;
    }
    .cta-link {
      text-align: center;
    }
  }
</style>
