---
interface Stat {
  key: string;
  value: string;
  label: string;
  iconPaths: string;
}

const stats: Stat[] = [
  {
    key: "duracion",
    value: "20 semanas",
    label: "Duración total",
    iconPaths: '<circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path>',
  },
  {
    key: "horas",
    value: "430 horas",
    label: "Certificadas",
    iconPaths: '<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z"></path>',
  },
  {
    key: "modalidad",
    value: "Remota",
    label: "Modalidad",
    iconPaths: '<rect x="2" y="3" width="20" height="14" rx="2"></rect><path d="M8 21h8M12 17v4"></path>',
  },
  {
    key: "inicio",
    value: "3 de agosto",
    label: "Inicio · semestre 2026-2",
    iconPaths: '<rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4M8 2v4M3 10h18"></path>',
  },
];

interface Bullet {
  key: string;
  title: string;
  desc: string;
  iconPaths: string;
}

const bullets: Bullet[] = [
  {
    key: "impacto",
    title: "Impacto sobre el terreno",
    desc: "Resolverás desafíos reales de la mano de organizaciones aliadas.",
    iconPaths: '<path d="M12 2a10 10 0 1 0 10 10"></path><path d="M12 12 8 8M12 12l6 2"></path>',
  },
  {
    key: "multidisciplinario",
    title: "Enfoque multidisciplinario",
    desc: "Trabajarás codo a codo con profesionales de diversas áreas, simulando equipos de proyectos reales.",
    iconPaths:
      '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"></path>',
  },
  {
    key: "mentores",
    title: "Mentores de primer nivel",
    desc: "Recibirás guía y retroalimentación de expertos que ya lideran el desarrollo social en la región.",
    iconPaths: '<path d="M12 2 4 5v6c0 5 3.5 8 8 10 4.5-2 8-5 8-10V5l-8-3Z"></path><path d="m9 12 2 2 4-4"></path>',
  },
  {
    key: "networking",
    title: "Networking latinoamericano",
    desc: "Te integrarás a una red viva de profesionales comprometidos con el cambio social.",
    iconPaths: '<circle cx="12" cy="12" r="10"></circle><path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20"></path>',
  },
];
---

<section class="info-programa" data-screen-label="Información del programa">
  <div class="cloud cloud--r1" aria-hidden="true"></div>
  <div class="cloud cloud--r2" aria-hidden="true"></div>
  <div class="cloud cloud--r3" aria-hidden="true"></div>
  <div class="cloud cloud--l1" aria-hidden="true"></div>
  <div class="cloud cloud--l2" aria-hidden="true"></div>
  <div class="cloud cloud--l3" aria-hidden="true"></div>
  <div class="ring ring--r" aria-hidden="true"></div>
  <div class="ring ring--l" aria-hidden="true"></div>
  <div class="grain" aria-hidden="true"></div>

  <div class="wrap">
    <div class="head">
      <div class="eyebrow" data-reveal data-delay="0">
        <span class="pulse-dot" aria-hidden="true">
          <span class="pulse-dot-ring"></span>
          <span class="pulse-dot-core"></span>
        </span>
        <span>Metodología 100% práctica y certificada</span>
      </div>
      <h2 data-reveal data-delay="140" data-infoh2>Información del programa</h2>
    </div>

    <div class="grid" data-infogrid>
      <div class="stat-grid" data-reveal="left" data-statgrid>
        {stats.map((stat) => (
          <div class={`stat-card stat-card--${stat.key}`}>
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" set:html={stat.iconPaths} />
            <div class="stat-num">{stat.value}</div>
            <div class="stat-label">{stat.label}</div>
          </div>
        ))}
      </div>

      <div class="experience-card">
        <span class="experience-title">Lo que hará distinta tu experiencia</span>
        <div class="experience-list">
          {bullets.map((bullet, i) => (
            <div class={`experience-item experience-item--${bullet.key}`} data-reveal data-delay={String(i * 110)}>
              <span class="experience-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" set:html={bullet.iconPaths} />
              </span>
              <div>
                <h4>{bullet.title}</h4>
                <p>{bullet.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { attachReveal } from "../../scripts/reveal";
  import { attachStatCardFit } from "../../scripts/stat-card-fit";

  const section = document.querySelector<HTMLElement>(".info-programa");
  if (section) {
    attachReveal(section, {
      threshold: 0.15,
      rootMargin: "0px 0px -12% 0px",
      repeat: true,
      duration: 950,
      distanceY: 46,
      distanceX: 58,
      easing: "cubic-bezier(.16,.8,.3,1)",
    });
    attachStatCardFit(section);
  }
</script>

<style>
  .info-programa {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(35deg, rgba(229, 38, 142, 0.3) 0%, rgba(46, 111, 224, 0.28) 16%, rgba(22, 164, 106, 0.2) 33%, transparent 54%),
      linear-gradient(-35deg, rgba(229, 38, 142, 0.3) 0%, rgba(46, 111, 224, 0.28) 16%, rgba(22, 164, 106, 0.2) 33%, transparent 54%),
      #ffffff;
    background-size: 180% 180%, 180% 180%, 100% 100%;
    animation: pe-grad 22s ease-in-out infinite;
    padding: 96px 48px 100px;
  }
  @keyframes pe-grad {
    0% { background-position: 0% 50%, 0% 50%, 0 0; }
    50% { background-position: 100% 50%, 100% 50%, 0 0; }
    100% { background-position: 0% 50%, 0% 50%, 0 0; }
  }

  .cloud {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }
  .cloud--r1 {
    right: -150px;
    top: -130px;
    width: 540px;
    height: 540px;
    background: radial-gradient(circle, rgba(22, 164, 106, 0.22), transparent 62%);
    filter: blur(74px);
    animation: pe-drift-2 22s ease-in-out infinite;
  }
  .cloud--r2 {
    right: -70px;
    bottom: -170px;
    width: 470px;
    height: 470px;
    background: radial-gradient(circle, rgba(46, 111, 224, 0.2), transparent 62%);
    filter: blur(70px);
    animation: pe-drift-3 26s ease-in-out infinite;
  }
  .cloud--r3 {
    right: 6%;
    top: 30%;
    width: 360px;
    height: 360px;
    background: radial-gradient(circle, rgba(229, 38, 142, 0.14), transparent 62%);
    filter: blur(64px);
    animation: pe-drift-1 30s ease-in-out infinite;
  }
  .cloud--l1 {
    left: -150px;
    top: -130px;
    width: 540px;
    height: 540px;
    background: radial-gradient(circle, rgba(22, 164, 106, 0.22), transparent 62%);
    filter: blur(74px);
    animation: pe-drift-1 23s ease-in-out infinite;
  }
  .cloud--l2 {
    left: -70px;
    bottom: -170px;
    width: 470px;
    height: 470px;
    background: radial-gradient(circle, rgba(229, 38, 142, 0.2), transparent 62%);
    filter: blur(70px);
    animation: pe-drift-2 27s ease-in-out infinite;
  }
  .cloud--l3 {
    left: 6%;
    top: 30%;
    width: 360px;
    height: 360px;
    background: radial-gradient(circle, rgba(46, 111, 224, 0.14), transparent 62%);
    filter: blur(64px);
    animation: pe-drift-3 31s ease-in-out infinite;
  }
  @keyframes pe-drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(110px, -70px) scale(1.18); }
  }
  @keyframes pe-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-90px, 60px) scale(1.22); }
  }
  @keyframes pe-drift-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(80px, 90px) scale(0.88); }
  }

  .ring {
    position: absolute;
    bottom: -100px;
    width: 500px;
    height: 500px;
    border: 1.5px solid rgba(52, 28, 101, 0.08);
    border-radius: 50%;
    pointer-events: none;
  }
  .ring--r {
    right: -120px;
  }
  .ring--l {
    left: -120px;
  }

  .grain {
    position: absolute;
    inset: 0;
    background-image: url("../../assets/images/noise-texture.png");
    background-size: auto;
    opacity: 0.3;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  .wrap {
    position: relative;
    z-index: 1;
    max-width: 1180px;
    margin: 0 auto;
  }

  .head {
    max-width: 680px;
    margin: 0 auto 44px;
    text-align: center;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 8px 17px;
    border: 1px solid rgba(19, 184, 154, 0.4);
    border-radius: 40px;
    background: rgba(19, 184, 154, 0.1);
    font-family: var(--font-label);
    font-size: 12.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #341c65;
    font-weight: 400;
  }
  .pulse-dot {
    position: relative;
    display: flex;
    width: 8px;
    height: 8px;
  }
  .pulse-dot-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #13b89a;
    animation: pe-pulse 2.2s ease-out infinite;
  }
  .pulse-dot-core {
    position: relative;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #13b89a;
  }
  @keyframes pe-pulse {
    0% { transform: scale(0.6); opacity: 0.5; }
    80% { opacity: 0; }
    100% { transform: scale(1.7); opacity: 0; }
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 44px;
    color: #341c65;
    line-height: 1.06;
    letter-spacing: -0.026em;
    margin-top: 12px;
    text-wrap: balance;
  }

  .grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 22px;
    align-items: start;
  }

  /* ---------- stat cards ---------- */
  .stat-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 14px;
  }
  .stat-card {
    min-width: 0;
    background: #fff;
    border: 1px solid rgba(52, 28, 101, 0.08);
    border-radius: 20px;
    padding: 24px 22px;
    box-shadow: 0 24px 54px -36px rgba(52, 28, 101, 0.45);
    transition: transform 0.38s cubic-bezier(0.2, 0.7, 0.2, 1), background 0.38s, box-shadow 0.38s, border-color 0.38s;
  }
  .stat-card:hover {
    transform: translateY(-6px) scale(1.03);
    box-shadow: 0 40px 80px -34px rgba(52, 28, 101, 0.5);
    border-color: transparent;
  }
  .stat-card:hover * {
    color: #fff;
  }
  .stat-card--duracion {
    color: #e5268e;
  }
  .stat-card--duracion:hover {
    background: linear-gradient(135deg, #b81570, #e5268e);
  }
  .stat-card--horas {
    color: #16a46a;
  }
  .stat-card--horas:hover {
    background: linear-gradient(135deg, #0e9e84, #16a46a);
  }
  .stat-card--modalidad {
    color: #2e6fe0;
  }
  .stat-card--modalidad:hover {
    background: linear-gradient(135deg, #1a4fb0, #2e6fe0);
  }
  .stat-card--inicio {
    color: #7b4dff;
  }
  .stat-card--inicio:hover {
    background: linear-gradient(135deg, #5a2b9c, #7b4dff);
  }
  .stat-card:hover svg {
    stroke: #fff;
  }
  .stat-num {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 26px;
    color: #341c65;
    margin-top: 14px;
    line-height: 1;
  }
  .stat-card:hover .stat-num {
    color: #fff;
  }
  .stat-label {
    font-size: 13px;
    color: #6b6786;
    margin-top: 5px;
  }

  /* ---------- experience card ---------- */
  .experience-card {
    background: #fff;
    border: 1px solid rgba(52, 28, 101, 0.08);
    border-radius: 24px;
    padding: 34px 36px;
    box-shadow: 0 40px 90px -50px rgba(52, 28, 101, 0.5);
  }
  .experience-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 18px;
    color: #341c65;
  }
  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 22px;
    margin-top: 24px;
  }
  .experience-item {
    display: flex;
    gap: 16px;
  }
  .experience-icon {
    flex: none;
    width: 44px;
    height: 44px;
    border-radius: 13px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .experience-item--impacto .experience-icon {
    background: rgba(229, 38, 142, 0.12);
    color: #e5268e;
  }
  .experience-item--multidisciplinario .experience-icon {
    background: rgba(19, 184, 154, 0.12);
    color: #13b89a;
  }
  .experience-item--mentores .experience-icon {
    background: rgba(46, 111, 224, 0.12);
    color: #2e6fe0;
  }
  .experience-item--networking .experience-icon {
    background: rgba(123, 77, 255, 0.14);
    color: #7b4dff;
  }
  .experience-item h4 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 16px;
    color: #341c65;
  }
  .experience-item p {
    font-size: 14px;
    line-height: 1.55;
    color: #6b6786;
    margin-top: 5px;
  }

  /* ---------- responsive ---------- */
  @media (max-width: 879.98px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 559.98px) {
    .info-programa {
      padding-top: 48px;
      padding-bottom: 52px;
    }
    h2 {
      font-size: 24px;
    }
    .stat-card {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      align-items: center;
      column-gap: 9px;
      row-gap: 2px;
      padding: 16px 14px;
    }
    .stat-card svg {
      grid-column: 1;
      grid-row: 1;
      width: 20px;
      height: 20px;
    }
    .stat-num {
      grid-column: 2;
      grid-row: 1;
      margin-top: 0;
      min-width: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .stat-label {
      grid-column: 1 / -1;
      grid-row: 2;
      margin-top: 2px;
    }
  }
</style>
