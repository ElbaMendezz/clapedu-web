---
import { Image } from "astro:assets";
import heroTeam from "../../assets/images/equipo-hero-team.webp";
---

<section class="hero">
  <div class="media" aria-hidden="true">
    <Image src={heroTeam} alt="" width={2400} height={1600} loading="eager" fetchpriority="high" />
    <div class="scrim scrim--side"></div>
    <div class="scrim scrim--bottom"></div>
  </div>

  <div class="content">
    <div class="eyebrow" data-reveal data-delay="100">
      <span class="eyebrow-dot" aria-hidden="true"></span>
      <span>conócenos · nuestra gente</span>
    </div>
    <h1 data-reveal data-delay="270">Equipo de <span class="accent">trabajo</span></h1>
    <p data-reveal data-delay="460">
      Detrás de cada palmada hay personas comprometidas con transformar el liderazgo en Latinoamérica.
      Conoce a quienes hacen posible a CLAP.
    </p>
  </div>
</section>

<script>
  import { attachReveal } from "../../scripts/reveal";

  const section = document.querySelector<HTMLElement>(".hero");
  if (section) {
    attachReveal(section, { threshold: 0.08, rootMargin: "0px 0px -4% 0px", repeat: false, duration: 700 });
  }
</script>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: #1a0f36;
    display: flex;
    align-items: center;
    min-height: 820px;
    padding: 170px 48px 92px;
  }

  .media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 8%;
    display: block;
  }
  .scrim {
    position: absolute;
    inset: 0;
  }
  .scrim--side {
    background: linear-gradient(
      90deg,
      rgba(22, 12, 46, 0.78) 0%,
      rgba(26, 15, 54, 0.42) 46%,
      rgba(20, 11, 42, 0.12) 78%,
      transparent 100%
    );
  }
  .scrim--bottom {
    background: linear-gradient(
      180deg,
      rgba(22, 12, 46, 0.3) 0%,
      transparent 30%,
      transparent 70%,
      rgba(15, 8, 38, 0.45) 100%
    );
  }

  .content {
    position: relative;
    z-index: 1;
    max-width: 1240px;
    margin: 80px auto 0;
    width: 100%;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 16px;
    border: 1px solid rgba(59, 224, 187, 0.4);
    border-radius: 40px;
    margin-bottom: 22px;
    background: rgba(59, 224, 187, 0.1);
    backdrop-filter: blur(6px);
    font-family: var(--font-label);
    font-size: 13px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #3be0bb;
    font-weight: 400;
  }
  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #3be0bb;
  }

  h1 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 58px;
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: #fff;
    text-wrap: balance;
    max-width: 760px;
  }
  h1 .accent {
    color: #3be0bb;
  }

  p {
    font-size: 18px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
    margin-top: 20px;
    max-width: 540px;
  }

  @media (max-width: 899.98px) {
    h1 {
      font-size: 48px;
    }
  }

  @media (max-width: 639.98px) {
    h1 {
      font-size: 40px;
    }
  }
</style>
