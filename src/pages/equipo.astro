---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/equipo/Hero.astro";
import EquipoDirectivo from "../components/equipo/EquipoDirectivo.astro";
import EquiposPorArea from "../components/equipo/EquiposPorArea.astro";
---

<BaseLayout
  title="Equipo de trabajo"
  titleOverride="Equipo CLAP | Profesionales y expertos en formación"
  description="Conoce al equipo multidisciplinario de CLAP, conformado por profesionales comprometidos con el liderazgo y el desarrollo humano."
  keywords="equipo CLAP, profesionales, expertos, consultores, liderazgo, facilitadores, coaches, desarrollo humano"
  path="/equipo"
  activeDropdown="conocenos"
  activeNavLink="equipo"
  breadcrumbs={[
    { name: "Inicio", path: "/" },
    { name: "Equipo de trabajo", path: "/equipo" },
  ]}
>
  <Hero />
  <EquipoDirectivo />
  <EquiposPorArea />
</BaseLayout>
