---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/metodologia/Hero.astro";
import Importancia from "../components/metodologia/Importancia.astro";
import Fases from "../components/metodologia/Fases.astro";
import Competencias from "../components/metodologia/Competencias.astro";
import CtaFinal from "../components/metodologia/CtaFinal.astro";
---

<BaseLayout
  title="Metodología"
  titleOverride="Metodología CLAP | Aprendizaje con propósito"
  description="Descubre la metodología CLAP, un modelo de aprendizaje que desarrolla liderazgo, propósito y competencias mediante experiencias transformadoras."
  keywords="metodología CLAP, aprendizaje, liderazgo, desarrollo humano, formación experiencial, propósito, innovación educativa"
  path="/metodologia"
  activeNavLink="metodologia"
  breadcrumbs={[
    { name: "Inicio", path: "/" },
    { name: "Metodología", path: "/metodologia" },
  ]}
>
  <Hero />
  <Importancia />
  <Fases />
  <Competencias />
  <CtaFinal />
</BaseLayout>
