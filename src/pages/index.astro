---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import Destacados from "../components/sections/Destacados.astro";
import Ecosistema from "../components/sections/Ecosistema.astro";
import MetodologiaHome from "../components/sections/MetodologiaHome.astro";
import Impacto from "../components/sections/Impacto.astro";
import Espacios from "../components/sections/Espacios.astro";
import Testimonios from "../components/sections/Testimonios.astro";
import Eventos from "../components/sections/Eventos.astro";
import Contacto from "../components/sections/Contacto.astro";
---

<BaseLayout
  title="Inicio"
  titleOverride="CLAP | Formación en liderazgo y desarrollo humano"
  description="Descubre los programas de CLAP para fortalecer el liderazgo, el propósito y el desarrollo humano con metodologías innovadoras y formación especializada."
  keywords="CLAP, Centro Latinoamericano del Propósito, liderazgo, desarrollo humano, formación, educación, propósito, programas especializados, metodologías, capacitación, cursos, Latinoamérica"
  path="/"
>
  <Hero />
  <Destacados />
  <Ecosistema />
  <MetodologiaHome />
  <Impacto />
  <Espacios />
  <Testimonios />
  <Eventos />
  <Contacto />
</BaseLayout>
