---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import Destacados from "../components/sections/Destacados.astro";
import Ecosistema from "../components/sections/Ecosistema.astro";
import MetodologiaHome from "../components/sections/MetodologiaHome.astro";
import Impacto from "../components/sections/Impacto.astro";
import Espacios from "../components/sections/Espacios.astro";
import Testimonios from "../components/sections/Testimonios.astro";
import Eventos from "../components/sections/Eventos.astro";
import Contacto from "../components/sections/Contacto.astro";
---

<BaseLayout
  title="Inicio"
  description="CLAP forma líderes capaces de convertir los desafíos sociales de Latinoamérica en soluciones reales."
  path="/"
>
  <Hero />
  <Destacados />
  <Ecosistema />
  <MetodologiaHome />
  <Impacto />
  <Espacios />
  <Testimonios />
  <Eventos />
  <Contacto />
</BaseLayout>
