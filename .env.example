# Clave de la API de Resend (dashboard → API Keys). Necesaria para que
# /api/contact pueda enviar el correo del formulario de contacto.
# Copia este archivo a .env (o configura la variable directamente en el
# panel de hosting) y pega tu clave real — nunca subas .env al repo.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# reCAPTCHA v3 (google.com/recaptcha/admin), clave del sitio clapedu.org.
# PUBLIC_ porque es pública por diseño (viaja en el HTML/JS del cliente):
# debe estar presente ya en build time, porque el home es una página
# prerenderizada (estática), no una ruta on-demand.
PUBLIC_RECAPTCHA_SITE_KEY=6Lxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clave secreta de reCAPTCHA v3 — nunca debe ir en el cliente. Se lee en
# tiempo de ejecución (process.env) en src/pages/api/contact.ts para
# verificar el token contra la API de Google.
RECAPTCHA_SECRET_KEY=6Lxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
