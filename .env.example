# Clave de la API de Resend (dashboard → API Keys). Necesaria para que
# /api/contact pueda enviar el correo del formulario de contacto.
# Copia este archivo a .env (o configura la variable directamente en el
# panel de hosting) y pega tu clave real — nunca subas .env al repo.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
